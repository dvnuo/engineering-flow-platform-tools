{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "efp.visual.input.graph_events.v1",
  "title": "EFP Visual Graph Events Input v1",
  "description": "Graph input with optional event stream for offline visual templates.",
  "type": "object",
  "required": ["nodes"],
  "additionalProperties": true,
  "properties": {
    "schema": {
      "type": "string",
      "const": "efp.visual.input.graph_events.v1"
    },
    "title": {
      "type": "string"
    },
    "nodes": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/node"
      }
    },
    "edges": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/edge"
      }
    },
    "events": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/event"
      }
    }
  },
  "$defs": {
    "object": {
      "type": "object",
      "additionalProperties": true
    },
    "node": {
      "type": "object",
      "required": ["id"],
      "additionalProperties": true,
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "label": {
          "type": "string"
        },
        "kind": {
          "type": "string"
        },
        "status": {
          "type": "string"
        },
        "group": {
          "type": "string"
        },
        "metadata": {
          "$ref": "#/$defs/object"
        },
        "metrics": {
          "$ref": "#/$defs/object"
        }
      }
    },
    "edge": {
      "type": "object",
      "required": ["from", "to"],
      "additionalProperties": true,
      "properties": {
        "from": {
          "type": "string",
          "minLength": 1
        },
        "to": {
          "type": "string",
          "minLength": 1
        },
        "kind": {
          "type": "string"
        },
        "label": {
          "type": "string"
        },
        "status": {
          "type": "string"
        },
        "weight": {
          "type": "number"
        },
        "metadata": {
          "$ref": "#/$defs/object"
        }
      }
    },
    "event": {
      "type": "object",
      "required": ["id"],
      "additionalProperties": true,
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "time": {
          "type": "string",
          "format": "date-time"
        },
        "kind": {
          "type": "string"
        },
        "node_id": {
          "type": "string"
        },
        "status": {
          "type": "string"
        },
        "label": {
          "type": "string"
        },
        "summary": {
          "type": "string"
        },
        "payload": {
          "$ref": "#/$defs/object"
        }
      }
    }
  }
}
