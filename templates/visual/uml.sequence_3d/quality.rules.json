{
  "schema": "efp.visual.template_quality_rules.v1",
  "template_id": "uml.sequence_3d",
  "label": {
    "max_overview_label_chars": 32,
    "max_detail_label_chars": 64,
    "require_summary_for_long_labels": true
  },
  "required_for_quality": [
    {
      "path": "$.visual.goal",
      "severity": "warning",
      "code": "visual_goal_missing",
      "suggestion": "Add visual.goal to explain what the viewer should understand first."
    },
    {
      "path": "$.visual.initial_focus_ids",
      "severity": "warning",
      "code": "visual_focus_missing",
      "suggestion": "Add visual.initial_focus_ids for the 2-5 most important semantic ids."
    },
    {
      "path": "$.visual.annotations",
      "severity": "warning",
      "code": "visual_annotations_missing",
      "suggestion": "Add annotations for critical path, risk, boundary, or result."
    }
  ],
  "semantic_rules": [
    {
      "code": "sequence_participants_must_be_lifelines",
      "severity": "warning",
      "description": "Participants should be semantic lifelines, not every function or method."
    }
  ],
  "template_specific": {
    "require_phase_colors": true,
    "require_unique_message_order": true,
    "max_visible_messages_overview": 14,
    "warn_messages_same_pair_over": 4
  }
}
