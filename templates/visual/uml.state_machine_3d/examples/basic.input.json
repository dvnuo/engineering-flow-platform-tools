{
  "schema": "efp.visual.input.uml.state_machine.v1",
  "title": "Agent Run State Machine",
  "states": [
    {
      "id": "queued",
      "label": "Queued",
      "kind": "initial",
      "region": "run",
      "entry": "reserve worker",
      "status": "ok"
    },
    {
      "id": "planning",
      "label": "Planning",
      "kind": "state",
      "region": "run",
      "entry": "read prompt",
      "status": "running"
    },
    {
      "id": "editing",
      "label": "Editing",
      "kind": "state",
      "region": "run",
      "entry": "modify files",
      "status": "running"
    },
    {
      "id": "verifying",
      "label": "Verifying",
      "kind": "state",
      "region": "run",
      "entry": "run tests",
      "status": "warning"
    },
    {
      "id": "blocked",
      "label": "Blocked",
      "kind": "state",
      "region": "exception",
      "entry": "request missing input",
      "status": "blocked"
    },
    {
      "id": "complete",
      "label": "Complete",
      "kind": "final",
      "region": "run",
      "entry": "report artifact",
      "status": "success"
    }
  ],
  "transitions": [
    {
      "from": "queued",
      "to": "planning",
      "trigger": "worker assigned",
      "action": "load workspace",
      "status": "success"
    },
    {
      "from": "planning",
      "to": "editing",
      "trigger": "plan accepted",
      "guard": "context complete",
      "status": "success"
    },
    {
      "from": "editing",
      "to": "verifying",
      "trigger": "files changed",
      "action": "run go test",
      "status": "running"
    },
    {
      "from": "verifying",
      "to": "editing",
      "trigger": "test failure",
      "guard": "fixable",
      "status": "warning"
    },
    {
      "from": "verifying",
      "to": "complete",
      "trigger": "all checks pass",
      "status": "success"
    },
    {
      "from": "planning",
      "to": "blocked",
      "trigger": "missing repo access",
      "status": "blocked"
    }
  ]
}
