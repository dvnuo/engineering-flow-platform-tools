{
  "schema": "efp.visual.template_input_schema.v1",
  "template_id": "agent.active_run_monitor",
  "input_schema_kind": "graph_events_v1",
  "json_schema": {
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "efp.visual.input.graph_events.v1",
    "title": "EFP Visual Graph Events Input v1",
    "description": "Graph input with optional event stream for offline visual templates.",
    "type": "object",
    "required": [
      "nodes"
    ],
    "additionalProperties": true,
    "properties": {
      "schema": {
        "type": "string",
        "const": "efp.visual.input.graph_events.v1"
      },
      "title": {
        "type": "string"
      },
      "nodes": {
        "type": "array",
        "items": {
          "$ref": "#/$defs/node"
        }
      },
      "edges": {
        "type": "array",
        "items": {
          "$ref": "#/$defs/edge"
        }
      },
      "events": {
        "type": "array",
        "items": {
          "$ref": "#/$defs/event"
        }
      }
    },
    "$defs": {
      "object": {
        "type": "object",
        "additionalProperties": true
      },
      "node": {
        "type": "object",
        "required": [
          "id"
        ],
        "additionalProperties": true,
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "label": {
            "type": "string"
          },
          "kind": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "group": {
            "type": "string"
          },
          "metadata": {
            "$ref": "#/$defs/object"
          },
          "metrics": {
            "$ref": "#/$defs/object"
          }
        }
      },
      "edge": {
        "type": "object",
        "required": [
          "from",
          "to"
        ],
        "additionalProperties": true,
        "properties": {
          "from": {
            "type": "string",
            "minLength": 1
          },
          "to": {
            "type": "string",
            "minLength": 1
          },
          "kind": {
            "type": "string"
          },
          "label": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "weight": {
            "type": "number"
          },
          "metadata": {
            "$ref": "#/$defs/object"
          }
        }
      },
      "event": {
        "type": "object",
        "required": [
          "id"
        ],
        "additionalProperties": true,
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "time": {
            "type": "string",
            "format": "date-time"
          },
          "kind": {
            "type": "string"
          },
          "node_id": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "label": {
            "type": "string"
          },
          "summary": {
            "type": "string"
          },
          "payload": {
            "$ref": "#/$defs/object"
          }
        }
      }
    }
  },
  "example": {
    "schema": "efp.visual.input.graph_events.v1",
    "title": "Active Run Monitor",
    "nodes": [
      {
        "id": "queue",
        "label": "Run queue",
        "kind": "queue",
        "status": "info"
      },
      {
        "id": "run_busy",
        "label": "Busy run",
        "kind": "run",
        "status": "busy"
      },
      {
        "id": "run_retry",
        "label": "Retrying run",
        "kind": "run",
        "status": "retry"
      },
      {
        "id": "run_idle",
        "label": "Idle run",
        "kind": "run",
        "status": "idle"
      },
      {
        "id": "run_blocked",
        "label": "Blocked run",
        "kind": "run",
        "status": "blocked"
      }
    ],
    "edges": [
      {
        "from": "queue",
        "to": "run_busy",
        "kind": "assigned"
      },
      {
        "from": "queue",
        "to": "run_retry",
        "kind": "retry"
      },
      {
        "from": "queue",
        "to": "run_idle",
        "kind": "parked"
      },
      {
        "from": "queue",
        "to": "run_blocked",
        "kind": "needs_input"
      }
    ],
    "events": [
      {
        "id": "m1",
        "time": "2026-06-03T13:30:00Z",
        "kind": "busy",
        "node_id": "run_busy",
        "summary": "Tool execution in progress."
      },
      {
        "id": "m2",
        "time": "2026-06-03T13:31:00Z",
        "kind": "retry",
        "node_id": "run_retry",
        "summary": "Retry scheduled."
      },
      {
        "id": "m3",
        "time": "2026-06-03T13:32:00Z",
        "kind": "idle",
        "node_id": "run_idle",
        "summary": "No pending task."
      },
      {
        "id": "m4",
        "time": "2026-06-03T13:33:00Z",
        "kind": "blocked",
        "node_id": "run_blocked",
        "summary": "Waiting for user input."
      }
    ]
  }
}
