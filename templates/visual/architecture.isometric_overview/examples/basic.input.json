{
  "schema": "efp.visual.input.isometric_architecture.v1",
  "title": "Order Platform Isometric Architecture",
  "summary": "Isometric service map for checkout request flow.",
  "theme": "architecture_light",
  "canvas": {
    "grid": {
      "enabled": true,
      "spacing": 4
    }
  },
  "camera": {
    "preset": "isometric"
  },
  "zones": [
    {
      "id": "edge",
      "label": "Edge",
      "bounds": {
        "x": 0,
        "y": 0,
        "w": 16,
        "h": 12
      },
      "presentation": {
        "boundary": "solid"
      }
    },
    {
      "id": "services",
      "label": "Application Services",
      "bounds": {
        "x": 18,
        "y": 0,
        "w": 20,
        "h": 18
      },
      "presentation": {
        "boundary": "solid"
      }
    },
    {
      "id": "data",
      "label": "Data Plane",
      "bounds": {
        "x": 18,
        "y": 20,
        "w": 20,
        "h": 12
      },
      "presentation": {
        "boundary": "dashed"
      }
    }
  ],
  "entities": [
    {
      "id": "client",
      "label": "Client App",
      "kind": "client",
      "zone": "edge",
      "position": {
        "x": 4,
        "y": 4
      },
      "size": {
        "w": 3,
        "d": 2,
        "h": 1
      },
      "importance": 0.9,
      "summary": "User-facing app that starts the checkout flow.",
      "presentation": {
        "shape": "actor_card",
        "icon": "generic.user",
        "label": "top",
        "leaderLine": true
      }
    },
    {
      "id": "api",
      "label": "Order API",
      "kind": "api",
      "zone": "services",
      "position": {
        "x": 22,
        "y": 5
      },
      "size": {
        "w": 4,
        "d": 3,
        "h": 2
      },
      "importance": 0.95,
      "summary": "Validates orders and coordinates writes.",
      "presentation": {
        "shape": "hex_service",
        "icon": "generic.api",
        "label": "top",
        "leaderLine": true
      }
    },
    {
      "id": "worker",
      "label": "Fulfillment Worker",
      "kind": "worker",
      "zone": "services",
      "position": {
        "x": 31,
        "y": 9
      },
      "size": {
        "w": 4,
        "d": 3,
        "h": 2
      },
      "importance": 0.75,
      "summary": "Handles asynchronous fulfillment jobs.",
      "presentation": {
        "shape": "service_box",
        "icon": "generic.job",
        "label": "top",
        "leaderLine": true
      }
    },
    {
      "id": "orders-db",
      "label": "Orders DB",
      "kind": "database",
      "zone": "data",
      "position": {
        "x": 24,
        "y": 25
      },
      "size": {
        "w": 4,
        "d": 3,
        "h": 3
      },
      "importance": 0.8,
      "summary": "Stores order records and status.",
      "presentation": {
        "shape": "database_cylinder",
        "icon": "generic.database",
        "label": "top",
        "leaderLine": true
      }
    }
  ],
  "links": [
    {
      "id": "client-api",
      "from": "client",
      "to": "api",
      "label": "places order",
      "kind": "calls",
      "directed": true,
      "presentation": {
        "arrow": "forward"
      }
    },
    {
      "id": "api-db",
      "from": "api",
      "to": "orders-db",
      "label": "writes order",
      "kind": "writes",
      "directed": true,
      "presentation": {
        "arrow": "forward"
      }
    },
    {
      "id": "api-worker",
      "from": "api",
      "to": "worker",
      "label": "dispatches fulfillment",
      "kind": "emits",
      "directed": true,
      "presentation": {
        "arrow": "forward"
      }
    }
  ],
  "controls": [
    {
      "id": "overview",
      "label": "Overview",
      "action": "overview"
    },
    {
      "id": "labels",
      "label": "Labels",
      "action": "toggle_labels"
    }
  ],
  "visual": {
    "goal": "Show the checkout request path across edge, service, and data zones.",
    "initial_focus_ids": [
      "client",
      "api",
      "orders-db"
    ],
    "hidden_detail_ids": [
      "api-worker"
    ],
    "narrative_steps": [
      {
        "id": "overview",
        "title": "Request enters the platform",
        "focus_ids": [
          "client",
          "api"
        ]
      }
    ],
    "annotations": [
      {
        "id": "api-note",
        "target_id": "api",
        "label": "Central routing service"
      }
    ]
  }
}
