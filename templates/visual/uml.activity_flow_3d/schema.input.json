{
  "schema": "efp.visual.template_input_schema.v1",
  "template_id": "uml.activity_flow_3d",
  "input_schema_kind": "uml_activity_v1",
  "json_schema": {
    "$schema": "json-schema-draft-2020-12",
    "type": "object",
    "required": [
      "schema",
      "actions"
    ],
    "properties": {
      "schema": {
        "const": "efp.visual.input.uml.activity.v1"
      },
      "title": {
        "type": "string"
      },
      "notes": {
        "type": "array",
        "items": {
          "type": "string"
        }
      },
      "lanes": {
        "type": "array",
        "items": {
          "type": "object",
          "required": [
            "id",
            "label"
          ],
          "properties": {
            "id": {
              "type": "string"
            },
            "label": {
              "type": "string"
            },
            "owner": {
              "type": "string"
            }
          }
        }
      },
      "actions": {
        "type": "array",
        "items": {
          "type": "object",
          "required": [
            "id",
            "label"
          ],
          "properties": {
            "id": {
              "type": "string"
            },
            "label": {
              "type": "string"
            },
            "kind": {
              "type": "string"
            },
            "lane_id": {
              "type": "string"
            },
            "status": {
              "type": "string"
            },
            "metadata": {
              "type": "object"
            }
          }
        }
      },
      "flows": {
        "type": "array",
        "items": {
          "type": "object",
          "required": [
            "from",
            "to"
          ],
          "properties": {
            "from": {
              "type": "string"
            },
            "to": {
              "type": "string"
            },
            "kind": {
              "type": "string"
            },
            "label": {
              "type": "string"
            },
            "condition": {
              "type": "string"
            },
            "status": {
              "type": "string"
            },
            "metadata": {
              "type": "object"
            }
          }
        }
      },
      "visual": {
        "type": "object",
        "description": "Visual authoring guidance for agents. Use this to control the first readable view, focus, hidden detail, narrative steps, and annotations without generating JavaScript.",
        "properties": {
          "goal": {
            "type": "string",
            "description": "One sentence describing what the viewer should understand first."
          },
          "audience": {
            "type": "string",
            "description": "Primary viewer, such as reviewer, operator, engineer, or stakeholder."
          },
          "initial_focus_ids": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "IDs that should be emphasized in the initial view."
          },
          "hidden_detail_ids": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Low-value detail IDs that may stay collapsed, muted, or hidden until search/focus."
          },
          "emphasis": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Short visual emphasis words such as bottleneck, risk, handoff, phase, or dependency."
          },
          "narrative_steps": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "id",
                "title"
              ],
              "properties": {
                "id": {
                  "type": "string"
                },
                "title": {
                  "type": "string"
                },
                "summary": {
                  "type": "string"
                },
                "focus_ids": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                }
              }
            },
            "description": "Ordered story beats the renderer and inspector can use to explain the diagram progressively."
          },
          "annotations": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "id",
                "target_id",
                "label"
              ],
              "properties": {
                "id": {
                  "type": "string"
                },
                "target_id": {
                  "type": "string"
                },
                "label": {
                  "type": "string"
                },
                "summary": {
                  "type": "string"
                },
                "priority": {
                  "type": "number"
                }
              }
            },
            "description": "Short callouts attached to existing semantic IDs."
          }
        }
      }
    }
  },
  "example": {
    "schema": "efp.visual.input.uml.activity.v1",
    "title": "Patch Review Activity Flow",
    "lanes": [
      {
        "id": "agent",
        "label": "Codex Agent",
        "owner": "automation"
      },
      {
        "id": "reviewer",
        "label": "Reviewer",
        "owner": "human"
      },
      {
        "id": "ci",
        "label": "CI",
        "owner": "platform"
      }
    ],
    "actions": [
      {
        "id": "start",
        "label": "Receive improvement request",
        "kind": "start",
        "lane_id": "reviewer",
        "status": "success"
      },
      {
        "id": "inspect",
        "label": "Inspect current source",
        "kind": "action",
        "lane_id": "agent",
        "status": "success",
        "metadata": {
          "focus": "latest branch"
        }
      },
      {
        "id": "patch",
        "label": "Apply scoped patch",
        "kind": "action",
        "lane_id": "agent",
        "status": "running"
      },
      {
        "id": "test",
        "label": "Run unit and smoke checks",
        "kind": "action",
        "lane_id": "ci",
        "status": "warning"
      },
      {
        "id": "decide",
        "label": "Checks pass?",
        "kind": "decision",
        "lane_id": "ci",
        "status": "warning"
      },
      {
        "id": "fix",
        "label": "Fix failed contract",
        "kind": "action",
        "lane_id": "agent",
        "status": "running"
      },
      {
        "id": "report",
        "label": "Report verified result",
        "kind": "end",
        "lane_id": "agent",
        "status": "success"
      }
    ],
    "flows": [
      {
        "from": "start",
        "to": "inspect",
        "label": "handoff"
      },
      {
        "from": "inspect",
        "to": "patch",
        "label": "source understood"
      },
      {
        "from": "patch",
        "to": "test",
        "label": "candidate patch"
      },
      {
        "from": "test",
        "to": "decide",
        "label": "results"
      },
      {
        "from": "decide",
        "to": "fix",
        "condition": "failed"
      },
      {
        "from": "fix",
        "to": "test",
        "label": "retry"
      },
      {
        "from": "decide",
        "to": "report",
        "condition": "passed"
      }
    ],
    "visual": {
      "goal": "Explain the uml activity flow 3d by starting from the most important objects, then reveal supporting detail on demand.",
      "audience": "reviewer",
      "initial_focus_ids": [
        "start",
        "inspect",
        "patch"
      ],
      "hidden_detail_ids": [
        "fix->test",
        "decide->report"
      ],
      "emphasis": [
        "first-view clarity",
        "progressive detail",
        "semantic focus"
      ],
      "narrative_steps": [
        {
          "id": "overview",
          "title": "Start with the main actors",
          "summary": "Show the core entities and the relationship the viewer should understand first.",
          "focus_ids": [
            "start",
            "inspect",
            "patch"
          ]
        },
        {
          "id": "detail",
          "title": "Reveal supporting detail",
          "summary": "Use search, filters, or expansion for secondary evidence and implementation detail.",
          "focus_ids": [
            "patch",
            "test",
            "decide"
          ]
        }
      ],
      "annotations": [
        {
          "id": "note-1",
          "target_id": "start",
          "label": "Start here",
          "summary": "Use start as a visual anchor for the uml activity flow 3d story.",
          "priority": 1.0
        },
        {
          "id": "note-2",
          "target_id": "inspect",
          "label": "Key relationship",
          "summary": "Use inspect as a visual anchor for the uml activity flow 3d story.",
          "priority": 0.82
        }
      ]
    }
  }
}
