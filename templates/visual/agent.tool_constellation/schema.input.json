{
  "schema": "efp.visual.template_input_schema.v1",
  "template_id": "agent.tool_constellation",
  "input_schema_kind": "graph_events_v1",
  "json_schema": {
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "efp.visual.input.graph_events.v1",
    "title": "EFP Visual Graph Events Input v1",
    "description": "Graph input with optional event stream for offline visual templates.",
    "type": "object",
    "required": [
      "nodes"
    ],
    "additionalProperties": true,
    "properties": {
      "schema": {
        "type": "string",
        "const": "efp.visual.input.graph_events.v1"
      },
      "title": {
        "type": "string"
      },
      "nodes": {
        "type": "array",
        "items": {
          "$ref": "#/$defs/node"
        }
      },
      "edges": {
        "type": "array",
        "items": {
          "$ref": "#/$defs/edge"
        }
      },
      "events": {
        "type": "array",
        "items": {
          "$ref": "#/$defs/event"
        }
      }
    },
    "$defs": {
      "object": {
        "type": "object",
        "additionalProperties": true
      },
      "node": {
        "type": "object",
        "required": [
          "id"
        ],
        "additionalProperties": true,
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "label": {
            "type": "string"
          },
          "kind": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "group": {
            "type": "string"
          },
          "metadata": {
            "$ref": "#/$defs/object"
          },
          "metrics": {
            "$ref": "#/$defs/object"
          }
        }
      },
      "edge": {
        "type": "object",
        "required": [
          "from",
          "to"
        ],
        "additionalProperties": true,
        "properties": {
          "from": {
            "type": "string",
            "minLength": 1
          },
          "to": {
            "type": "string",
            "minLength": 1
          },
          "kind": {
            "type": "string"
          },
          "label": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "weight": {
            "type": "number"
          },
          "metadata": {
            "$ref": "#/$defs/object"
          }
        }
      },
      "event": {
        "type": "object",
        "required": [
          "id"
        ],
        "additionalProperties": true,
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "time": {
            "type": "string",
            "format": "date-time"
          },
          "kind": {
            "type": "string"
          },
          "node_id": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "label": {
            "type": "string"
          },
          "summary": {
            "type": "string"
          },
          "payload": {
            "$ref": "#/$defs/object"
          }
        }
      }
    }
  },
  "example": {
    "schema": "efp.visual.input.graph_events.v1",
    "title": "Tool Constellation",
    "nodes": [
      {
        "id": "agent",
        "label": "Agent",
        "kind": "agent",
        "status": "success"
      },
      {
        "id": "bash",
        "label": "Bash",
        "kind": "tool",
        "status": "success"
      },
      {
        "id": "read",
        "label": "Read files",
        "kind": "tool",
        "status": "success"
      },
      {
        "id": "write",
        "label": "Write files",
        "kind": "tool",
        "status": "warning"
      },
      {
        "id": "browser",
        "label": "Browser probe",
        "kind": "tool",
        "status": "info"
      },
      {
        "id": "visual",
        "label": "Visual render",
        "kind": "tool",
        "status": "success"
      }
    ],
    "edges": [
      {
        "from": "agent",
        "to": "bash",
        "kind": "exec"
      },
      {
        "from": "agent",
        "to": "read",
        "kind": "inspect"
      },
      {
        "from": "agent",
        "to": "write",
        "kind": "edit"
      },
      {
        "from": "agent",
        "to": "browser",
        "kind": "probe"
      },
      {
        "from": "agent",
        "to": "visual",
        "kind": "render"
      }
    ],
    "events": [
      {
        "id": "c1",
        "time": "2026-06-03T13:10:00Z",
        "kind": "tool_started",
        "node_id": "bash",
        "summary": "Listed files."
      },
      {
        "id": "c2",
        "time": "2026-06-03T13:11:00Z",
        "kind": "tool_started",
        "node_id": "read",
        "summary": "Read source."
      },
      {
        "id": "c3",
        "time": "2026-06-03T13:12:00Z",
        "kind": "tool_started",
        "node_id": "write",
        "summary": "Applied patch."
      },
      {
        "id": "c4",
        "time": "2026-06-03T13:13:00Z",
        "kind": "tool_finished",
        "node_id": "visual",
        "summary": "Rendered artifact."
      }
    ]
  }
}
