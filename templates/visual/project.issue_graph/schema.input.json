{
  "schema": "efp.visual.template_input_schema.v1",
  "template_id": "project.issue_graph",
  "input_schema_kind": "graph_v1",
  "json_schema": {
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "efp.visual.input.graph.v1",
    "title": "EFP Visual Graph Input v1",
    "description": "Graph input for offline visual templates.",
    "type": "object",
    "required": [
      "nodes"
    ],
    "additionalProperties": true,
    "properties": {
      "schema": {
        "type": "string",
        "const": "efp.visual.input.graph.v1"
      },
      "title": {
        "type": "string"
      },
      "nodes": {
        "type": "array",
        "items": {
          "$ref": "#/$defs/node"
        }
      },
      "edges": {
        "type": "array",
        "items": {
          "$ref": "#/$defs/edge"
        }
      }
    },
    "$defs": {
      "object": {
        "type": "object",
        "additionalProperties": true
      },
      "node": {
        "type": "object",
        "required": [
          "id"
        ],
        "additionalProperties": true,
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "label": {
            "type": "string"
          },
          "kind": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "group": {
            "type": "string"
          },
          "metadata": {
            "$ref": "#/$defs/object"
          },
          "metrics": {
            "$ref": "#/$defs/object"
          }
        }
      },
      "edge": {
        "type": "object",
        "required": [
          "from",
          "to"
        ],
        "additionalProperties": true,
        "properties": {
          "from": {
            "type": "string",
            "minLength": 1
          },
          "to": {
            "type": "string",
            "minLength": 1
          },
          "kind": {
            "type": "string"
          },
          "label": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "weight": {
            "type": "number"
          },
          "metadata": {
            "$ref": "#/$defs/object"
          }
        }
      }
    }
  },
  "example": {
    "schema": "efp.visual.input.graph.v1",
    "title": "Issue Graph",
    "nodes": [
      {
        "id": "epic",
        "label": "Epic VIS-1",
        "kind": "epic",
        "status": "success"
      },
      {
        "id": "story_a",
        "label": "Story VIS-2",
        "kind": "story",
        "status": "success"
      },
      {
        "id": "story_b",
        "label": "Story VIS-3",
        "kind": "story",
        "status": "warning"
      },
      {
        "id": "pr",
        "label": "PR 42",
        "kind": "pull_request",
        "status": "pending"
      },
      {
        "id": "tests",
        "label": "Contract tests",
        "kind": "test",
        "status": "pending"
      }
    ],
    "edges": [
      {
        "from": "epic",
        "to": "story_a",
        "kind": "contains"
      },
      {
        "from": "epic",
        "to": "story_b",
        "kind": "contains"
      },
      {
        "from": "story_a",
        "to": "pr",
        "kind": "implemented_by"
      },
      {
        "from": "pr",
        "to": "tests",
        "kind": "verified_by"
      }
    ]
  }
}
