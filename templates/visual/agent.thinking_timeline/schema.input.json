{
  "schema": "efp.visual.template_input_schema.v1",
  "template_id": "agent.thinking_timeline",
  "input_schema_kind": "graph_events_v1",
  "json_schema": {
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "efp.visual.input.graph_events.v1",
    "title": "EFP Visual Graph Events Input v1",
    "description": "Graph input with optional event stream for offline visual templates.",
    "type": "object",
    "required": [
      "nodes"
    ],
    "additionalProperties": true,
    "properties": {
      "schema": {
        "type": "string",
        "const": "efp.visual.input.graph_events.v1"
      },
      "title": {
        "type": "string"
      },
      "nodes": {
        "type": "array",
        "items": {
          "$ref": "#/$defs/node"
        }
      },
      "edges": {
        "type": "array",
        "items": {
          "$ref": "#/$defs/edge"
        }
      },
      "events": {
        "type": "array",
        "items": {
          "$ref": "#/$defs/event"
        }
      }
    },
    "$defs": {
      "object": {
        "type": "object",
        "additionalProperties": true
      },
      "node": {
        "type": "object",
        "required": [
          "id"
        ],
        "additionalProperties": true,
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "label": {
            "type": "string"
          },
          "kind": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "group": {
            "type": "string"
          },
          "metadata": {
            "$ref": "#/$defs/object"
          },
          "metrics": {
            "$ref": "#/$defs/object"
          }
        }
      },
      "edge": {
        "type": "object",
        "required": [
          "from",
          "to"
        ],
        "additionalProperties": true,
        "properties": {
          "from": {
            "type": "string",
            "minLength": 1
          },
          "to": {
            "type": "string",
            "minLength": 1
          },
          "kind": {
            "type": "string"
          },
          "label": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "weight": {
            "type": "number"
          },
          "metadata": {
            "$ref": "#/$defs/object"
          }
        }
      },
      "event": {
        "type": "object",
        "required": [
          "id"
        ],
        "additionalProperties": true,
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "time": {
            "type": "string",
            "format": "date-time"
          },
          "kind": {
            "type": "string"
          },
          "node_id": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "label": {
            "type": "string"
          },
          "summary": {
            "type": "string"
          },
          "payload": {
            "$ref": "#/$defs/object"
          }
        }
      }
    }
  },
  "example": {
    "schema": "efp.visual.input.graph_events.v1",
    "title": "Thinking Timeline",
    "nodes": [
      {
        "id": "reasoning",
        "label": "Reasoning",
        "kind": "reasoning",
        "status": "success"
      },
      {
        "id": "tool",
        "label": "Tool call",
        "kind": "tool",
        "status": "success"
      },
      {
        "id": "permission",
        "label": "Permission",
        "kind": "permission",
        "status": "warning"
      },
      {
        "id": "text",
        "label": "Text update",
        "kind": "text",
        "status": "info"
      },
      {
        "id": "finish",
        "label": "Step finish",
        "kind": "finish",
        "status": "success"
      }
    ],
    "edges": [
      {
        "from": "reasoning",
        "to": "tool",
        "kind": "sequence"
      },
      {
        "from": "tool",
        "to": "permission",
        "kind": "guard"
      },
      {
        "from": "permission",
        "to": "text",
        "kind": "resume"
      },
      {
        "from": "text",
        "to": "finish",
        "kind": "sequence"
      }
    ],
    "events": [
      {
        "id": "t1",
        "time": "2026-06-03T13:00:00Z",
        "kind": "reasoning",
        "node_id": "reasoning",
        "label": "Reasoning phase",
        "status": "success",
        "summary": "Approach selected."
      },
      {
        "id": "t2",
        "time": "2026-06-03T13:01:00Z",
        "kind": "tool",
        "node_id": "tool",
        "label": "Tool call",
        "status": "success",
        "summary": "Read repository files."
      },
      {
        "id": "t3",
        "time": "2026-06-03T13:02:00Z",
        "kind": "permission",
        "node_id": "permission",
        "label": "Permission gate",
        "status": "warning",
        "summary": "Checked write boundary."
      },
      {
        "id": "t4",
        "time": "2026-06-03T13:03:00Z",
        "kind": "text",
        "node_id": "text",
        "label": "User update",
        "status": "info",
        "summary": "Progress reported."
      },
      {
        "id": "t5",
        "time": "2026-06-03T13:04:00Z",
        "kind": "step_finish",
        "node_id": "finish",
        "label": "Step finished",
        "status": "success",
        "summary": "Phase completed."
      }
    ]
  }
}
