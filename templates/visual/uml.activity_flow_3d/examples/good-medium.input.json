{
  "schema": "efp.visual.input.uml.activity.v1",
  "title": "Patch Review Activity Flow",
  "lanes": [
    {
      "id": "agent",
      "label": "Codex Agent",
      "owner": "automation"
    },
    {
      "id": "reviewer",
      "label": "Reviewer",
      "owner": "human"
    },
    {
      "id": "ci",
      "label": "CI",
      "owner": "platform"
    }
  ],
  "actions": [
    {
      "id": "start",
      "label": "Receive improvement request",
      "kind": "start",
      "lane_id": "reviewer",
      "status": "success"
    },
    {
      "id": "inspect",
      "label": "Inspect current source",
      "kind": "action",
      "lane_id": "agent",
      "status": "success",
      "metadata": {
        "focus": "latest branch"
      }
    },
    {
      "id": "patch",
      "label": "Apply scoped patch",
      "kind": "action",
      "lane_id": "agent",
      "status": "running"
    },
    {
      "id": "test",
      "label": "Run unit and smoke checks",
      "kind": "action",
      "lane_id": "ci",
      "status": "warning"
    },
    {
      "id": "decide",
      "label": "Checks pass?",
      "kind": "decision",
      "lane_id": "ci",
      "status": "warning"
    },
    {
      "id": "fix",
      "label": "Fix failed contract",
      "kind": "action",
      "lane_id": "agent",
      "status": "running"
    },
    {
      "id": "report",
      "label": "Report verified result",
      "kind": "end",
      "lane_id": "agent",
      "status": "success"
    }
  ],
  "flows": [
    {
      "from": "start",
      "to": "inspect",
      "label": "handoff"
    },
    {
      "from": "inspect",
      "to": "patch",
      "label": "source understood"
    },
    {
      "from": "patch",
      "to": "test",
      "label": "candidate patch"
    },
    {
      "from": "test",
      "to": "decide",
      "label": "results"
    },
    {
      "from": "decide",
      "to": "fix",
      "condition": "failed"
    },
    {
      "from": "fix",
      "to": "test",
      "label": "retry"
    },
    {
      "from": "decide",
      "to": "report",
      "condition": "passed"
    }
  ],
  "visual": {
    "goal": "Explain the uml activity flow 3d by starting from the most important objects, then reveal supporting detail on demand.",
    "audience": "reviewer",
    "initial_focus_ids": [
      "start",
      "inspect",
      "patch"
    ],
    "hidden_detail_ids": [
      "fix->test",
      "decide->report"
    ],
    "emphasis": [
      "first-view clarity",
      "progressive detail",
      "semantic focus"
    ],
    "narrative_steps": [
      {
        "id": "overview",
        "title": "Start with the main actors",
        "summary": "Show the core entities and the relationship the viewer should understand first.",
        "focus_ids": [
          "start",
          "inspect",
          "patch"
        ]
      },
      {
        "id": "detail",
        "title": "Reveal supporting detail",
        "summary": "Use search, filters, or expansion for secondary evidence and implementation detail.",
        "focus_ids": [
          "patch",
          "test",
          "decide"
        ]
      }
    ],
    "annotations": [
      {
        "id": "note-1",
        "target_id": "start",
        "label": "Start here",
        "summary": "Use start as a visual anchor for the uml activity flow 3d story.",
        "priority": 1.0
      },
      {
        "id": "note-2",
        "target_id": "inspect",
        "label": "Key relationship",
        "summary": "Use inspect as a visual anchor for the uml activity flow 3d story.",
        "priority": 0.82
      }
    ]
  }
}
