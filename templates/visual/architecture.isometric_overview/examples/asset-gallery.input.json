  "visual": {
    "goal": "Review whether each local logo/model badge is visually readable in the isometric renderer.",
    "initial_focus_ids": [
      "nginx",
      "spring",
      "mysql",
      "redis",
      "kafka",
      "jenkins"
    ],
    "annotations": [
      {
        "id": "badge-review-note",
        "target_id": "nginx",
        "label": "Every entity should show a top label icon and a readable local badge."
      }
    ],
    "assumptions": [
      "This gallery is intentionally sparse so badge readability can be inspected without relationship clutter."
    ],
    "narrative_steps": [
      {
        "id": "overview",
        "title": "Read the local asset coverage",
        "summary": "Scan the four zones to confirm every entity has a top label icon and local model badge.",
        "focus_ids": [
          "nginx",
          "spring",
          "mysql",
          "redis",
          "kafka",
          "jenkins"
        ]
      },
      {
        "id": "data-and-ops",
        "title": "Compare data and operations logos",
        "summary": "Check database, cache, messaging, CI, and observability badges for readability at the default camera angle.",
        "focus_ids": [
          "mysql",
          "postgresql",
          "mongodb",
          "redis",
          "prometheus",
          "grafana"
        ]
      }
    ]
  },
  "view": {
    "labelMode": "detail",
    "maxInitialObjects": 18,
    "maxInitialRelationships": 8
  },
  "renderHints": {
    "colorBy": "kind",
    "routeCollisionAvoidance": "basic",
    "preferExplicitRoutes": true,
    "showLegend": true,
    "badgeMode": "icon_and_model",
    "badgeSize": "large",
    "badgePlacement": "front",
    "labelIcon": true
  }
