{
  "schema": "efp.visual.template_input_schema.v1",
  "template_id": "uml.state_machine_3d",
  "input_schema_kind": "uml_state_machine_v1",
  "json_schema": {
    "$schema": "json-schema-draft-2020-12",
    "type": "object",
    "required": [
      "schema",
      "states",
      "transitions"
    ],
    "properties": {
      "schema": {
        "const": "efp.visual.input.uml.state_machine.v1"
      },
      "title": {
        "type": "string"
      },
      "notes": {
        "type": "array",
        "items": {
          "type": "string"
        }
      },
      "states": {
        "type": "array",
        "items": {
          "type": "object",
          "required": [
            "id",
            "label"
          ],
          "properties": {
            "id": {
              "type": "string"
            },
            "label": {
              "type": "string"
            },
            "kind": {
              "type": "string"
            },
            "region": {
              "type": "string"
            },
            "entry": {
              "type": "string"
            },
            "exit": {
              "type": "string"
            },
            "status": {
              "type": "string"
            },
            "metadata": {
              "type": "object"
            }
          }
        }
      },
      "transitions": {
        "type": "array",
        "items": {
          "type": "object",
          "required": [
            "from",
            "to",
            "trigger"
          ],
          "properties": {
            "from": {
              "type": "string"
            },
            "to": {
              "type": "string"
            },
            "trigger": {
              "type": "string"
            },
            "guard": {
              "type": "string"
            },
            "action": {
              "type": "string"
            },
            "status": {
              "type": "string"
            },
            "metadata": {
              "type": "object"
            }
          }
        }
      },
      "visual": {
        "type": "object",
        "description": "Visual authoring guidance for agents. Use this to control the first readable view, focus, hidden detail, narrative steps, and annotations without generating JavaScript.",
        "properties": {
          "goal": {
            "type": "string",
            "description": "One sentence describing what the viewer should understand first."
          },
          "audience": {
            "type": "string",
            "description": "Primary viewer, such as reviewer, operator, engineer, or stakeholder."
          },
          "initial_focus_ids": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "IDs that should be emphasized in the initial view."
          },
          "hidden_detail_ids": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Low-value detail IDs that may stay collapsed, muted, or hidden until search/focus."
          },
          "emphasis": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Short visual emphasis words such as bottleneck, risk, handoff, phase, or dependency."
          },
          "narrative_steps": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "id",
                "title"
              ],
              "properties": {
                "id": {
                  "type": "string"
                },
                "title": {
                  "type": "string"
                },
                "summary": {
                  "type": "string"
                },
                "focus_ids": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                }
              }
            },
            "description": "Ordered story beats the renderer and inspector can use to explain the diagram progressively."
          },
          "annotations": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "id",
                "target_id",
                "label"
              ],
              "properties": {
                "id": {
                  "type": "string"
                },
                "target_id": {
                  "type": "string"
                },
                "label": {
                  "type": "string"
                },
                "summary": {
                  "type": "string"
                },
                "priority": {
                  "type": "number"
                }
              }
            },
            "description": "Short callouts attached to existing semantic IDs."
          }
        }
      }
    }
  },
  "example": {
    "schema": "efp.visual.input.uml.state_machine.v1",
    "title": "Agent Run State Machine",
    "states": [
      {
        "id": "queued",
        "label": "Queued",
        "kind": "initial",
        "region": "run",
        "entry": "reserve worker",
        "status": "ok"
      },
      {
        "id": "planning",
        "label": "Planning",
        "kind": "state",
        "region": "run",
        "entry": "read prompt",
        "status": "running"
      },
      {
        "id": "editing",
        "label": "Editing",
        "kind": "state",
        "region": "run",
        "entry": "modify files",
        "status": "running"
      },
      {
        "id": "verifying",
        "label": "Verifying",
        "kind": "state",
        "region": "run",
        "entry": "run tests",
        "status": "warning"
      },
      {
        "id": "blocked",
        "label": "Blocked",
        "kind": "state",
        "region": "exception",
        "entry": "request missing input",
        "status": "blocked"
      },
      {
        "id": "complete",
        "label": "Complete",
        "kind": "final",
        "region": "run",
        "entry": "report artifact",
        "status": "success"
      }
    ],
    "transitions": [
      {
        "from": "queued",
        "to": "planning",
        "trigger": "worker assigned",
        "action": "load workspace",
        "status": "success"
      },
      {
        "from": "planning",
        "to": "editing",
        "trigger": "plan accepted",
        "guard": "context complete",
        "status": "success"
      },
      {
        "from": "editing",
        "to": "verifying",
        "trigger": "files changed",
        "action": "run go test",
        "status": "running"
      },
      {
        "from": "verifying",
        "to": "editing",
        "trigger": "test failure",
        "guard": "fixable",
        "status": "warning"
      },
      {
        "from": "verifying",
        "to": "complete",
        "trigger": "all checks pass",
        "status": "success"
      },
      {
        "from": "planning",
        "to": "blocked",
        "trigger": "missing repo access",
        "status": "blocked"
      }
    ],
    "visual": {
      "goal": "Explain the uml state machine 3d by starting from the most important objects, then reveal supporting detail on demand.",
      "audience": "reviewer",
      "initial_focus_ids": [
        "queued",
        "planning",
        "editing"
      ],
      "hidden_detail_ids": [
        "verifying->complete",
        "planning->blocked"
      ],
      "emphasis": [
        "first-view clarity",
        "progressive detail",
        "semantic focus"
      ],
      "narrative_steps": [
        {
          "id": "overview",
          "title": "Start with the main actors",
          "summary": "Show the core entities and the relationship the viewer should understand first.",
          "focus_ids": [
            "queued",
            "planning",
            "editing"
          ]
        },
        {
          "id": "detail",
          "title": "Reveal supporting detail",
          "summary": "Use search, filters, or expansion for secondary evidence and implementation detail.",
          "focus_ids": [
            "editing",
            "verifying",
            "blocked"
          ]
        }
      ],
      "annotations": [
        {
          "id": "note-1",
          "target_id": "queued",
          "label": "Start here",
          "summary": "Use queued as a visual anchor for the uml state machine 3d story.",
          "priority": 1.0
        },
        {
          "id": "note-2",
          "target_id": "planning",
          "label": "Key relationship",
          "summary": "Use planning as a visual anchor for the uml state machine 3d story.",
          "priority": 0.82
        }
      ]
    }
  }
}
