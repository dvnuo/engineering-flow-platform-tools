  "visual": {
    "goal": "Read the topology from left to right: client, edge, gateway, services, registry, state, storage, and logs.",
    "assumptions": [
      "Each microservice entity represents a logical service, not every pod replica.",
      "Nacos, Redis, and MySQL are shown as clustered logical nodes because exact host placement is outside the overview.",
      "Orthogonal routes are chosen to reduce crossings in the service and state zones."
    ],
    "initial_focus_ids": [
      "pc",
      "nginx",
      "api-gateway",
      "microservice-a",
      "mysql-master"
    ]
  },
