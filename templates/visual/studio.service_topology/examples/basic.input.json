{
  "schema": "efp.visual.input.studio.v1",
  "title": "Order Service Topology Studio",
  "goal": "Explain the primary order-processing service path.",
  "audience": "platform engineer",
  "assumptions": ["Topology is scoped to checkout write path."],
  "hero": {
    "type": "topology",
    "title": "Order Processing Topology",
    "summary": "Ingress, compute, queue, and database dependencies.",
    "data": {
      "nodes": [
        {"id": "api", "label": "Order API", "kind": "api", "provider": "aws", "service": "api_gateway", "platform": "aws", "status": "ok", "importance": 0.92, "summary": "Receives checkout requests.", "presentation": {"shape": "hex_service", "icon": "aws.api_gateway", "color": "#38bdf8"}},
        {"id": "orders", "label": "Orders", "kind": "service", "provider": "aws", "service": "lambda", "platform": "aws", "status": "ok", "importance": 0.9, "summary": "Owns order orchestration.", "presentation": {"shape": "service_box", "icon": "aws.lambda", "color": "#22c55e"}},
        {"id": "db", "label": "Orders DB", "kind": "database", "provider": "aws", "service": "rds", "platform": "aws", "status": "ok", "importance": 0.78, "summary": "Persists order state.", "presentation": {"shape": "database_cylinder", "icon": "aws.rds", "color": "#60a5fa"}}
      ],
      "edges": [
        {"id": "api-to-orders", "from": "api", "to": "orders", "kind": "calls", "label": "calls", "directed": true, "importance": 0.88, "summary": "Synchronous order creation call.", "presentation": {"arrow": "forward", "lineStyle": "solid", "flow": true}},
        {"id": "orders-to-db", "from": "orders", "to": "db", "kind": "writes", "label": "writes", "directed": true, "importance": 0.82, "summary": "Persists order record.", "presentation": {"arrow": "forward", "lineStyle": "solid", "flow": true}}
      ]
    }
  },
  "navigation": [{"id": "nav-orders", "label": "Orders", "target_id": "orders-panel", "icon": "aws.lambda", "summary": "Service detail."}],
  "panels": [
    {"id": "overview-panel", "type": "overview", "title": "Topology Overview", "target_refs": ["api", "orders", "db"], "summary": "Checkout writes enter the API and persist through Orders.", "items": [{"label": "path", "value": "api -> orders -> db"}], "metrics": [{"label": "services", "value": "3"}], "evidence": [{"label": "service catalog", "source": "platform"}], "content": {"owner": "checkout platform"}, "presentation": {"shape": "service_box", "icon": "generic.service"}},
    {"id": "orders-panel", "type": "service", "title": "Orders Service", "target_refs": ["orders", "api-to-orders", "orders-to-db"], "summary": "Orders owns orchestration and persistence.", "metrics": [{"label": "slo", "value": "99.9"}], "evidence": [{"label": "runbook", "source": "orders-runbook"}], "content": {"owner": "checkout team"}, "presentation": {"shape": "service_box", "icon": "aws.lambda"}}
  ],
  "controls": [
    {"id": "focus-orders", "label": "Focus orders", "type": "focus", "target": "orders", "action": "focus"},
    {"id": "filter-provider", "label": "AWS", "type": "filter", "target": "provider", "action": "aws"}
  ],
  "annotations": [{"id": "anno-orders", "label": "Core", "target_id": "orders", "summary": "Orders is the orchestration hub."}],
  "view": {"colorBy": "provider", "mode": "overview"},
  "renderHints": {"showLegend": true, "palette": "cloud_provider", "iconMode": "billboard", "colorBy": "provider"},
  "visual": {
    "goal": "Start with the order service path.",
    "initial_focus_ids": ["api", "orders", "db", "orders-panel"],
    "hidden_detail_ids": ["orders-to-db"],
    "narrative_steps": [{"id": "overview", "title": "Follow checkout", "summary": "API calls Orders, then Orders writes state.", "focus_ids": ["api", "orders", "db"]}],
    "annotations": [{"id": "visual-orders", "label": "Core service", "target_id": "orders", "summary": "Orders owns the transaction.", "priority": 0.9}]
