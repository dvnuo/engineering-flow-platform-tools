{
  "schema": "efp.visual.template_input_schema.v1",
  "template_id": "codebase.test_failure_map",
  "input_schema_kind": "graph_events_v1",
  "json_schema": {
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "efp.visual.input.graph_events.v1",
    "title": "EFP Visual Graph Events Input v1",
    "description": "Graph input with optional event stream for offline visual templates.",
    "type": "object",
    "required": [
      "nodes"
    ],
    "additionalProperties": true,
    "properties": {
      "schema": {
        "type": "string",
        "const": "efp.visual.input.graph_events.v1"
      },
      "title": {
        "type": "string"
      },
      "nodes": {
        "type": "array",
        "items": {
          "$ref": "#/$defs/node"
        }
      },
      "edges": {
        "type": "array",
        "items": {
          "$ref": "#/$defs/edge"
        }
      },
      "events": {
        "type": "array",
        "items": {
          "$ref": "#/$defs/event"
        }
      }
    },
    "$defs": {
      "object": {
        "type": "object",
        "additionalProperties": true
      },
      "node": {
        "type": "object",
        "required": [
          "id"
        ],
        "additionalProperties": true,
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "label": {
            "type": "string"
          },
          "kind": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "group": {
            "type": "string"
          },
          "metadata": {
            "$ref": "#/$defs/object"
          },
          "metrics": {
            "$ref": "#/$defs/object"
          }
        }
      },
      "edge": {
        "type": "object",
        "required": [
          "from",
          "to"
        ],
        "additionalProperties": true,
        "properties": {
          "from": {
            "type": "string",
            "minLength": 1
          },
          "to": {
            "type": "string",
            "minLength": 1
          },
          "kind": {
            "type": "string"
          },
          "label": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "weight": {
            "type": "number"
          },
          "metadata": {
            "$ref": "#/$defs/object"
          }
        }
      },
      "event": {
        "type": "object",
        "required": [
          "id"
        ],
        "additionalProperties": true,
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "time": {
            "type": "string",
            "format": "date-time"
          },
          "kind": {
            "type": "string"
          },
          "node_id": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "label": {
            "type": "string"
          },
          "summary": {
            "type": "string"
          },
          "payload": {
            "$ref": "#/$defs/object"
          }
        }
      }
    }
  },
  "example": {
    "schema": "efp.visual.input.graph_events.v1",
    "title": "Test Failure Map",
    "nodes": [
      {
        "id": "test_render",
        "label": "TestRenderArtifact",
        "kind": "test",
        "status": "error"
      },
      {
        "id": "test_offline",
        "label": "TestOfflineScan",
        "kind": "test",
        "status": "warning"
      },
      {
        "id": "render_module",
        "label": "render package",
        "kind": "module",
        "status": "warning"
      },
      {
        "id": "scanner",
        "label": "offline scanner",
        "kind": "module",
        "status": "warning"
      },
      {
        "id": "template",
        "label": "template assets",
        "kind": "asset",
        "status": "info"
      }
    ],
    "edges": [
      {
        "from": "test_render",
        "to": "render_module",
        "kind": "fails_on"
      },
      {
        "from": "test_offline",
        "to": "scanner",
        "kind": "fails_on"
      },
      {
        "from": "render_module",
        "to": "template",
        "kind": "reads"
      },
      {
        "from": "scanner",
        "to": "template",
        "kind": "scans"
      }
    ],
    "events": [
      {
        "id": "tf1",
        "time": "2026-06-03T14:00:00Z",
        "kind": "test_failed",
        "node_id": "test_render",
        "summary": "Render contract failed."
      },
      {
        "id": "tf2",
        "time": "2026-06-03T14:01:00Z",
        "kind": "test_failed",
        "node_id": "test_offline",
        "summary": "Offline scan caught a token."
      },
      {
        "id": "tf3",
        "time": "2026-06-03T14:02:00Z",
        "kind": "investigate",
        "node_id": "scanner",
        "summary": "Scanner token reviewed."
      }
    ]
  }
}
