{
  "schema": "efp.visual.template_input_schema.v1",
  "template_id": "knowledge.evidence_board",
  "input_schema_kind": "evidence_v1",
  "json_schema": {
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "efp.visual.input.evidence.v1",
    "title": "EFP Visual Evidence Input v1",
    "description": "Evidence board input for offline visual templates.",
    "type": "object",
    "required": [
      "claims",
      "sources"
    ],
    "additionalProperties": true,
    "properties": {
      "schema": {
        "type": "string",
        "const": "efp.visual.input.evidence.v1"
      },
      "title": {
        "type": "string"
      },
      "claims": {
        "type": "array",
        "items": {
          "$ref": "#/$defs/claim"
        }
      },
      "sources": {
        "type": "array",
        "items": {
          "$ref": "#/$defs/source"
        }
      },
      "links": {
        "type": "array",
        "items": {
          "$ref": "#/$defs/link"
        }
      }
    },
    "$defs": {
      "object": {
        "type": "object",
        "additionalProperties": true
      },
      "claim": {
        "type": "object",
        "required": [
          "id"
        ],
        "additionalProperties": true,
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "text": {
            "type": "string"
          },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "status": {
            "type": "string"
          },
          "metadata": {
            "$ref": "#/$defs/object"
          }
        }
      },
      "source": {
        "type": "object",
        "required": [
          "id"
        ],
        "additionalProperties": true,
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "title": {
            "type": "string"
          },
          "kind": {
            "type": "string"
          },
          "reliability": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "metadata": {
            "$ref": "#/$defs/object"
          }
        }
      },
      "link": {
        "type": "object",
        "required": [
          "claim_id",
          "source_id"
        ],
        "additionalProperties": true,
        "properties": {
          "claim_id": {
            "type": "string",
            "minLength": 1
          },
          "source_id": {
            "type": "string",
            "minLength": 1
          },
          "relation": {
            "type": "string"
          },
          "weight": {
            "type": "number"
          }
        }
      }
    }
  },
  "example": {
    "schema": "efp.visual.input.evidence.v1",
    "title": "Evidence Board",
    "claims": [
      {
        "id": "claim_1",
        "text": "Artifacts can open offline.",
        "confidence": 0.92,
        "status": "supported"
      },
      {
        "id": "claim_2",
        "text": "Remote assets are required.",
        "confidence": 0.12,
        "status": "refuted"
      },
      {
        "id": "claim_3",
        "text": "Relative paths support proxy subpaths.",
        "confidence": 0.84,
        "status": "supported"
      }
    ],
    "sources": [
      {
        "id": "source_1",
        "title": "Offline scanner",
        "kind": "test",
        "reliability": 0.9
      },
      {
        "id": "source_2",
        "title": "Rendered manifest",
        "kind": "artifact",
        "reliability": 0.86
      },
      {
        "id": "source_3",
        "title": "Template contract",
        "kind": "spec",
        "reliability": 0.82
      }
    ],
    "links": [
      {
        "claim_id": "claim_1",
        "source_id": "source_1",
        "relation": "supports"
      },
      {
        "claim_id": "claim_2",
        "source_id": "source_3",
        "relation": "refutes"
      },
      {
        "claim_id": "claim_3",
        "source_id": "source_2",
        "relation": "supports"
      }
    ]
  }
}
