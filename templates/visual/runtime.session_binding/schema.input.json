{
  "schema": "efp.visual.template_input_schema.v1",
  "template_id": "runtime.session_binding",
  "input_schema_kind": "graph_v1",
  "json_schema": {
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "efp.visual.input.graph.v1",
    "title": "EFP Visual Graph Input v1",
    "description": "Graph input for offline visual templates.",
    "type": "object",
    "required": [
      "nodes"
    ],
    "additionalProperties": true,
    "properties": {
      "schema": {
        "type": "string",
        "const": "efp.visual.input.graph.v1"
      },
      "title": {
        "type": "string"
      },
      "nodes": {
        "type": "array",
        "items": {
          "$ref": "#/$defs/node"
        }
      },
      "edges": {
        "type": "array",
        "items": {
          "$ref": "#/$defs/edge"
        }
      }
    },
    "$defs": {
      "object": {
        "type": "object",
        "additionalProperties": true
      },
      "node": {
        "type": "object",
        "required": [
          "id"
        ],
        "additionalProperties": true,
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "label": {
            "type": "string"
          },
          "kind": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "group": {
            "type": "string"
          },
          "metadata": {
            "$ref": "#/$defs/object"
          },
          "metrics": {
            "$ref": "#/$defs/object"
          }
        }
      },
      "edge": {
        "type": "object",
        "required": [
          "from",
          "to"
        ],
        "additionalProperties": true,
        "properties": {
          "from": {
            "type": "string",
            "minLength": 1
          },
          "to": {
            "type": "string",
            "minLength": 1
          },
          "kind": {
            "type": "string"
          },
          "label": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "weight": {
            "type": "number"
          },
          "metadata": {
            "$ref": "#/$defs/object"
          }
        }
      }
    }
  },
  "example": {
    "schema": "efp.visual.input.graph.v1",
    "title": "Runtime Session Binding",
    "nodes": [
      {
        "id": "conversation",
        "label": "Portal conversation",
        "kind": "conversation",
        "status": "success"
      },
      {
        "id": "root_session",
        "label": "OpenCode root session",
        "kind": "session",
        "status": "success"
      },
      {
        "id": "messages",
        "label": "Messages",
        "kind": "stream",
        "status": "info"
      },
      {
        "id": "events",
        "label": "Events",
        "kind": "stream",
        "status": "info"
      },
      {
        "id": "status",
        "label": "Status",
        "kind": "state",
        "status": "success"
      }
    ],
    "edges": [
      {
        "from": "conversation",
        "to": "root_session",
        "kind": "bind"
      },
      {
        "from": "root_session",
        "to": "messages",
        "kind": "append"
      },
      {
        "from": "root_session",
        "to": "events",
        "kind": "emit"
      },
      {
        "from": "events",
        "to": "status",
        "kind": "derive"
      }
    ]
  }
}
