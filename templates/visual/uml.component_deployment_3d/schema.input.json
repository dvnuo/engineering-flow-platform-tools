{
  "schema": "efp.visual.template_input_schema.v1",
  "template_id": "uml.component_deployment_3d",
  "input_schema_kind": "uml_component_deployment_v1",
  "json_schema": {
    "$schema": "json-schema-draft-2020-12",
    "type": "object",
    "required": [
      "schema",
      "components"
    ],
    "properties": {
      "schema": {
        "const": "efp.visual.input.uml.component_deployment.v1"
      },
      "title": {
        "type": "string"
      },
      "notes": {
        "type": "array",
        "items": {
          "type": "string"
        }
      },
      "deployments": {
        "type": "array",
        "items": {
          "type": "object",
          "required": [
            "id",
            "label"
          ],
          "properties": {
            "id": {
              "type": "string"
            },
            "label": {
              "type": "string"
            },
            "kind": {
              "type": "string"
            },
            "status": {
              "type": "string"
            },
            "metadata": {
              "type": "object"
            },
            "metrics": {
              "type": "object"
            }
          }
        }
      },
      "components": {
        "type": "array",
        "items": {
          "type": "object",
          "required": [
            "id",
            "label"
          ],
          "properties": {
            "id": {
              "type": "string"
            },
            "label": {
              "type": "string"
            },
            "kind": {
              "type": "string"
            },
            "deployment_id": {
              "type": "string"
            },
            "interfaces": {
              "type": "array"
            },
            "responsibilities": {
              "type": "array"
            },
            "status": {
              "type": "string"
            },
            "metadata": {
              "type": "object"
            },
            "metrics": {
              "type": "object"
            }
          }
        }
      },
      "links": {
        "type": "array",
        "items": {
          "type": "object",
          "required": [
            "from",
            "to"
          ],
          "properties": {
            "from": {
              "type": "string"
            },
            "to": {
              "type": "string"
            },
            "kind": {
              "type": "string"
            },
            "protocol": {
              "type": "string"
            },
            "label": {
              "type": "string"
            },
            "status": {
              "type": "string"
            },
            "metadata": {
              "type": "object"
            }
          }
        }
      },
      "visual": {
        "type": "object",
        "description": "Visual authoring guidance for agents. Use this to control the first readable view, focus, hidden detail, narrative steps, and annotations without generating JavaScript.",
        "properties": {
          "goal": {
            "type": "string",
            "description": "One sentence describing what the viewer should understand first."
          },
          "audience": {
            "type": "string",
            "description": "Primary viewer, such as reviewer, operator, engineer, or stakeholder."
          },
          "initial_focus_ids": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "IDs that should be emphasized in the initial view."
          },
          "hidden_detail_ids": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Low-value detail IDs that may stay collapsed, muted, or hidden until search/focus."
          },
          "emphasis": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Short visual emphasis words such as bottleneck, risk, handoff, phase, or dependency."
          },
          "narrative_steps": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "id",
                "title"
              ],
              "properties": {
                "id": {
                  "type": "string"
                },
                "title": {
                  "type": "string"
                },
                "summary": {
                  "type": "string"
                },
                "focus_ids": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                }
              }
            },
            "description": "Ordered story beats the renderer and inspector can use to explain the diagram progressively."
          },
          "annotations": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "id",
                "target_id",
                "label"
              ],
              "properties": {
                "id": {
                  "type": "string"
                },
                "target_id": {
                  "type": "string"
                },
                "label": {
                  "type": "string"
                },
                "summary": {
                  "type": "string"
                },
                "priority": {
                  "type": "number"
                }
              }
            },
            "description": "Short callouts attached to existing semantic IDs."
          }
        }
      }
    }
  },
  "example": {
    "schema": "efp.visual.input.uml.component_deployment.v1",
    "title": "Portal Runtime Deployment Components",
    "deployments": [
      {
        "id": "browser",
        "label": "User Browser",
        "kind": "client",
        "status": "success"
      },
      {
        "id": "portal-node",
        "label": "Portal Node",
        "kind": "server",
        "status": "success",
        "metrics": {
          "cpu": 0.42
        }
      },
      {
        "id": "runtime-vm",
        "label": "Runtime VM",
        "kind": "worker",
        "status": "warning"
      },
      {
        "id": "artifact-store",
        "label": "Artifact Store",
        "kind": "storage",
        "status": "success"
      }
    ],
    "components": [
      {
        "id": "portal-ui",
        "label": "Portal UI",
        "kind": "component",
        "deployment_id": "browser",
        "interfaces": [
          "artifact viewer"
        ],
        "responsibilities": [
          "render visual output"
        ],
        "status": "success"
      },
      {
        "id": "portal-api",
        "label": "Portal API",
        "kind": "component",
        "deployment_id": "portal-node",
        "interfaces": [
          "session proxy",
          "artifact proxy"
        ],
        "responsibilities": [
          "route visual artifacts"
        ],
        "status": "success"
      },
      {
        "id": "codex-runner",
        "label": "Codex Runner",
        "kind": "component",
        "deployment_id": "runtime-vm",
        "interfaces": [
          "command execution"
        ],
        "responsibilities": [
          "generate input json"
        ],
        "status": "warning"
      },
      {
        "id": "visual-cli",
        "label": "Visual CLI",
        "kind": "component",
        "deployment_id": "runtime-vm",
        "interfaces": [
          "render",
          "inspect-input",
          "doctor"
        ],
        "responsibilities": [
          "validate and render templates"
        ],
        "status": "success"
      },
      {
        "id": "static-artifact",
        "label": "Static Artifact",
        "kind": "component",
        "deployment_id": "artifact-store",
        "interfaces": [
          "index.html",
          "data.js"
        ],
        "responsibilities": [
          "offline visual output"
        ],
        "status": "success"
      }
    ],
    "links": [
      {
        "from": "browser",
        "to": "portal-api",
        "kind": "proxy",
        "protocol": "portal proxy",
        "label": "view artifact"
      },
      {
        "from": "portal-api",
        "to": "codex-runner",
        "kind": "control",
        "label": "start run"
      },
      {
        "from": "codex-runner",
        "to": "visual-cli",
        "kind": "exec",
        "label": "visual render"
      },
      {
        "from": "visual-cli",
        "to": "static-artifact",
        "kind": "writes",
        "label": "offline files"
      },
      {
        "from": "portal-api",
        "to": "static-artifact",
        "kind": "serves",
        "label": "relative static site"
      }
    ],
    "visual": {
      "goal": "Explain the uml component deployment 3d by starting from the most important objects, then reveal supporting detail on demand.",
      "audience": "reviewer",
      "initial_focus_ids": [
        "portal-ui",
        "portal-api",
        "codex-runner"
      ],
      "hidden_detail_ids": [
        "visual-cli->static-artifact",
        "portal-api->static-artifact"
      ],
      "emphasis": [
        "first-view clarity",
        "progressive detail",
        "semantic focus"
      ],
      "narrative_steps": [
        {
          "id": "overview",
          "title": "Start with the main actors",
          "summary": "Show the core entities and the relationship the viewer should understand first.",
          "focus_ids": [
            "portal-ui",
            "portal-api",
            "codex-runner"
          ]
        },
        {
          "id": "detail",
          "title": "Reveal supporting detail",
          "summary": "Use search, filters, or expansion for secondary evidence and implementation detail.",
          "focus_ids": [
            "codex-runner",
            "visual-cli",
            "static-artifact"
          ]
        }
      ],
      "annotations": [
        {
          "id": "note-1",
          "target_id": "portal-ui",
          "label": "Start here",
          "summary": "Use portal-ui as a visual anchor for the uml component deployment 3d story.",
          "priority": 1.0
        },
        {
          "id": "note-2",
          "target_id": "portal-api",
          "label": "Key relationship",
          "summary": "Use portal-api as a visual anchor for the uml component deployment 3d story.",
          "priority": 0.82
        }
      ]
    }
  }
}
