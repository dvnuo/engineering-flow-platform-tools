        "trigger": "test failure"
      },
      {
        "from": "verifying",
        "status": "success",
        "to": "complete",
        "trigger": "all checks pass"
      },
      {
        "from": "planning",
        "status": "blocked",
        "to": "blocked",
        "trigger": "missing repo access"
      }
