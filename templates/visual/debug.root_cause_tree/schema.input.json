{
  "schema": "efp.visual.template_input_schema.v1",
  "template_id": "debug.root_cause_tree",
  "input_schema_kind": "graph_v1",
  "json_schema": {
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "efp.visual.input.graph.v1",
    "title": "EFP Visual Graph Input v1",
    "description": "Graph input for offline visual templates.",
    "type": "object",
    "required": [
      "nodes"
    ],
    "additionalProperties": true,
    "properties": {
      "schema": {
        "type": "string",
        "const": "efp.visual.input.graph.v1"
      },
      "title": {
        "type": "string"
      },
      "nodes": {
        "type": "array",
        "items": {
          "$ref": "#/$defs/node"
        }
      },
      "edges": {
        "type": "array",
        "items": {
          "$ref": "#/$defs/edge"
        }
      }
    },
    "$defs": {
      "object": {
        "type": "object",
        "additionalProperties": true
      },
      "node": {
        "type": "object",
        "required": [
          "id"
        ],
        "additionalProperties": true,
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "label": {
            "type": "string"
          },
          "kind": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "group": {
            "type": "string"
          },
          "metadata": {
            "$ref": "#/$defs/object"
          },
          "metrics": {
            "$ref": "#/$defs/object"
          }
        }
      },
      "edge": {
        "type": "object",
        "required": [
          "from",
          "to"
        ],
        "additionalProperties": true,
        "properties": {
          "from": {
            "type": "string",
            "minLength": 1
          },
          "to": {
            "type": "string",
            "minLength": 1
          },
          "kind": {
            "type": "string"
          },
          "label": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "weight": {
            "type": "number"
          },
          "metadata": {
            "$ref": "#/$defs/object"
          }
        }
      }
    }
  },
  "example": {
    "schema": "efp.visual.input.graph.v1",
    "title": "Root Cause Tree",
    "nodes": [
      {
        "id": "symptom",
        "label": "Symptom",
        "kind": "symptom",
        "status": "error",
        "group": "0"
      },
      {
        "id": "cause_a",
        "label": "Stale manifest",
        "kind": "cause",
        "status": "warning",
        "group": "1"
      },
      {
        "id": "cause_b",
        "label": "Bad path",
        "kind": "cause",
        "status": "warning",
        "group": "1"
      },
      {
        "id": "evidence",
        "label": "Scanner evidence",
        "kind": "evidence",
        "status": "info",
        "group": "2"
      },
      {
        "id": "fix",
        "label": "Fix path join",
        "kind": "fix",
        "status": "success",
        "group": "3"
      }
    ],
    "edges": [
      {
        "from": "symptom",
        "to": "cause_a",
        "kind": "caused_by"
      },
      {
        "from": "symptom",
        "to": "cause_b",
        "kind": "caused_by"
      },
      {
        "from": "cause_b",
        "to": "evidence",
        "kind": "supported_by"
      },
      {
        "from": "evidence",
        "to": "fix",
        "kind": "resolved_by"
      }
    ]
  }
}
