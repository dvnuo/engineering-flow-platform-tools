  "example": {
    "schema": "efp.visual.input.uml.class.v1",
    "title": "Visual Rendering Class Structure",
    "classes": [
      {
        "id": "renderer",
        "name": "VisualRenderer",
        "stereotype": "service",
        "package": "render",
        "attributes": [
          "registry: RendererRegistry",
          "runtime: RuntimeAssets"
        ],
        "operations": [
          "render(input)",
          "inspectOutput()"
        ],
        "responsibility": "Coordinates template rendering",
        "metrics": {
          "importance": 0.9
        }
      },
      {
        "id": "template",
        "name": "TemplateManifest",
        "stereotype": "entity",
        "package": "manifest",
        "attributes": [
          "id",
          "renderer",
          "inputSchemaKind"
        ],
        "operations": [
          "validate()"
        ],
        "responsibility": "Declares template contract"
      },
      {
        "id": "schema",
        "name": "InputSchema",
        "stereotype": "value",
        "package": "schema",
        "attributes": [
          "kind",
          "jsonSchema",
          "example"
        ],
        "operations": [
          "describe()"
        ],
        "responsibility": "Guides agents before input generation"
      },
      {
        "id": "artifact",
        "name": "VisualArtifact",
        "stereotype": "entity",
        "package": "render",
        "attributes": [
          "entrypoint",
          "files",
          "offline"
        ],
        "operations": [
          "listFiles()"
        ],
        "responsibility": "Captures output contract"
      },
      {
        "id": "doctor",
        "name": "TemplateDoctor",
        "stereotype": "service",
        "package": "quality",
        "attributes": [
          "expectedCounts"
        ],
        "operations": [
          "checkRegistry()",
          "renderExamples()"
        ],
        "responsibility": "Verifies every template"
      }
    ],
    "relationships": [
      {
        "from": "renderer",
        "to": "template",
        "kind": "uses",
        "label": "loads manifest"
      },
      {
        "from": "template",
        "to": "schema",
        "kind": "composes",
        "label": "input contract"
      },
      {
        "from": "renderer",
        "to": "artifact",
        "kind": "creates",
        "label": "offline artifact"
      },
      {
        "from": "doctor",
        "to": "template",
        "kind": "validates",
        "label": "manifest and example"
      },
      {
        "from": "doctor",
        "to": "artifact",
        "kind": "verifies",
        "label": "required files"
      }
    ],
    "visual": {
      "goal": "Explain the uml class structure 2.5d by starting from the most important objects, then reveal supporting detail on demand.",
      "audience": "reviewer",
      "initial_focus_ids": [
        "renderer",
        "template",
        "schema"
      ],
      "hidden_detail_ids": [
        "doctor->template",
        "doctor->artifact"
      ],
      "emphasis": [
        "first-view clarity",
        "progressive detail",
        "semantic focus"
      ],
      "narrative_steps": [
        {
          "id": "overview",
          "title": "Start with the main actors",
          "summary": "Show the core entities and the relationship the viewer should understand first.",
          "focus_ids": [
            "renderer",
            "template",
            "schema"
          ]
        },
        {
          "id": "detail",
          "title": "Reveal supporting detail",
          "summary": "Use search, filters, or expansion for secondary evidence and implementation detail.",
          "focus_ids": [
            "schema",
            "artifact",
            "doctor"
          ]
        }
      ],
      "annotations": [
        {
          "id": "note-1",
          "target_id": "renderer",
          "label": "Start here",
          "summary": "Use renderer as a visual anchor for the uml class structure 2 story.",
          "priority": 1.0
        },
        {
          "id": "note-2",
          "target_id": "template",
          "label": "Key relationship",
          "summary": "Use template as a visual anchor for the uml class structure 2 story.",
          "priority": 0.82
        }
      ]
    }
  }
