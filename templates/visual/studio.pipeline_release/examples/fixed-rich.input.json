{
  "schema": "efp.visual.input.studio.v1",
  "title": "Standard Pipeline Release Studio",
  "goal": "Explain build, scan, canary, approval, and rollback readiness.",
  "audience": "release manager",
  "assumptions": ["Security scan and canary telemetry are current for release candidate 2026.06."],
  "hero": {
    "type": "pipeline",
    "title": "Standard Pipeline Release",
    "summary": "A release page with gates, evidence, risks, and controls.",
    "data": {
      "nodes": [
        {"id": "source", "label": "Source", "kind": "service", "provider": "aws", "service": "s3", "platform": "aws", "status": "success", "importance": 0.7, "summary": "Signed source bundle.", "presentation": {"shape": "bucket", "icon": "aws.s3", "color": "#38bdf8"}},
        {"id": "build", "label": "Build", "kind": "job", "provider": "jenkins", "service": "jenkins", "platform": "jenkins", "status": "success", "importance": 0.88, "summary": "CI build and unit tests.", "presentation": {"shape": "ci_card", "icon": "jenkins", "color": "#60a5fa"}},
        {"id": "scan", "label": "Scan", "kind": "decision", "provider": "aws", "service": "cloudwatch", "platform": "aws", "status": "success", "importance": 0.82, "summary": "Security and policy scan passed.", "presentation": {"shape": "diamond", "icon": "generic.decision", "color": "#22c55e"}},
        {"id": "canary", "label": "Canary", "kind": "service", "provider": "aws", "service": "lambda", "platform": "aws", "status": "warning", "importance": 0.92, "summary": "Canary receives five percent traffic.", "presentation": {"shape": "service_box", "icon": "aws.lambda", "color": "#f59e0b"}},
        {"id": "orders-db", "label": "Orders DB", "kind": "database", "provider": "aws", "service": "rds", "platform": "aws", "status": "ok", "importance": 0.72, "summary": "Rollback-safe schema version.", "presentation": {"shape": "database_cylinder", "icon": "aws.rds", "color": "#22c55e"}},
        {"id": "rollback", "label": "Rollback", "kind": "risk", "provider": "aws", "service": "cloudwatch", "platform": "aws", "status": "ready", "importance": 0.8, "summary": "Rollback plan is ready.", "presentation": {"shape": "warning_prism", "icon": "generic.warning", "color": "#fb7185"}}
      ],
      "edges": [
        {"id": "source-to-build", "from": "source", "to": "build", "kind": "validates", "label": "builds", "directed": true, "importance": 0.74, "summary": "Source bundle triggers build.", "presentation": {"arrow": "forward", "lineStyle": "solid", "flow": true}},
        {"id": "build-to-scan", "from": "build", "to": "scan", "kind": "validates", "label": "scans", "directed": true, "importance": 0.78, "summary": "Build artifact moves through policy scan.", "presentation": {"arrow": "forward", "lineStyle": "solid", "flow": true}},
        {"id": "scan-to-canary", "from": "scan", "to": "canary", "kind": "deploys", "label": "deploys", "directed": true, "importance": 0.88, "summary": "Approved artifact deploys to canary.", "presentation": {"arrow": "forward", "lineStyle": "solid", "flow": true}},
        {"id": "canary-to-db", "from": "canary", "to": "orders-db", "kind": "writes", "label": "writes", "directed": true, "importance": 0.68, "summary": "Canary writes compatible records.", "presentation": {"arrow": "forward", "lineStyle": "dashed", "flow": true}},
        {"id": "canary-to-rollback", "from": "canary", "to": "rollback", "kind": "blocks", "label": "may trigger", "directed": true, "importance": 0.84, "summary": "Canary alarms can trigger rollback.", "presentation": {"arrow": "forward", "lineStyle": "dotted", "flow": true}}
      ],
      "events": [
        {"id": "scan-pass", "label": "Scan pass", "kind": "event", "status": "success", "summary": "Policy scan completed.", "presentation": {"shape": "diamond", "icon": "generic.decision", "color": "#22c55e"}},
        {"id": "canary-latency", "label": "Canary latency", "kind": "risk", "status": "warning", "summary": "Latency p95 is above expansion threshold.", "presentation": {"shape": "warning_prism", "icon": "generic.warning", "color": "#f59e0b"}}
      ]
    }
  },
  "navigation": [
    {"id": "nav-overview", "label": "Overview", "target_id": "overview-panel", "icon": "generic.pipeline", "summary": "Release state."},
    {"id": "nav-gates", "label": "Gates", "target_id": "gate-panel", "icon": "generic.decision", "summary": "Gate evidence."},
    {"id": "nav-rollback", "label": "Rollback", "target_id": "rollback-panel", "icon": "generic.warning", "summary": "Rollback readiness."}
  ],
  "panels": [
    {"id": "overview-panel", "type": "overview", "title": "Release Readiness", "target_refs": ["source", "build", "scan", "canary"], "summary": "Release is ready except for canary latency watch.", "items": [{"label": "phase", "value": "canary"}], "metrics": [{"label": "checks passed", "value": "42/44"}], "evidence": [{"label": "release bundle", "source": "artifact manifest"}], "content": {"status": "watch", "owner": "release engineering"}, "presentation": {"shape": "service_box", "icon": "generic.pipeline"}},
    {"id": "gate-panel", "type": "gate", "title": "Gate Evidence", "target_refs": ["build", "scan", "scan-pass"], "summary": "Build and policy gates passed with local evidence.", "items": [{"label": "scan", "value": "passed"}], "metrics": [{"label": "critical findings", "value": "0"}], "evidence": [{"label": "Jenkins run", "source": "jenkins"}, {"label": "scan report", "source": "policy"}], "content": {"next_action": "Keep watch on canary."}, "presentation": {"shape": "diamond", "icon": "generic.decision"}},
    {"id": "rollback-panel", "type": "risk", "title": "Rollback Readiness", "target_refs": ["rollback", "canary-to-rollback", "orders-db"], "summary": "Rollback is ready and database version is compatible.", "items": [{"label": "blast radius", "value": "5 percent traffic"}], "metrics": [{"label": "rollback time", "value": "8 min"}], "evidence": [{"label": "runbook", "source": "release runbook"}], "content": {"next_action": "Hold approval until latency clears."}, "presentation": {"shape": "warning_prism", "icon": "generic.warning"}}
  ],
  "controls": [
    {"id": "focus-canary", "label": "Focus canary", "type": "focus", "target": "canary", "action": "focus"},
    {"id": "filter-warning", "label": "Warnings", "type": "filter", "target": "status", "action": "warning"},
    {"id": "show-rollback", "label": "Rollback", "type": "toggle", "target": "rollback-panel", "action": "show"}
  ],
  "annotations": [
    {"id": "anno-latency", "label": "Latency", "target_id": "canary-latency", "summary": "Primary release risk."},
    {"id": "anno-rollback", "label": "Ready", "target_id": "rollback", "summary": "Rollback plan is ready."}
  ],
  "view": {"colorBy": "provider", "mode": "overview", "labelMode": "overview"},
  "renderHints": {"showLegend": true, "palette": "cloud_provider", "iconMode": "billboard", "colorBy": "provider"},
  "visual": {
    "goal": "Start with canary risk and rollback readiness.",
    "initial_focus_ids": ["canary", "rollback", "overview-panel", "gate-panel"],
    "hidden_detail_ids": ["canary-to-db"],
    "narrative_steps": [
      {"id": "overview", "title": "Read release state", "summary": "The build and scan are clear.", "focus_ids": ["build", "scan", "overview-panel"]},
      {"id": "canary-risk", "title": "Inspect canary", "summary": "Latency is holding approval.", "focus_ids": ["canary", "canary-latency", "gate-panel"]},
      {"id": "rollback", "title": "Confirm rollback", "summary": "Rollback is ready if canary worsens.", "focus_ids": ["rollback", "rollback-panel"]}
    ],
    "annotations": [
      {"id": "visual-latency", "label": "Watch latency", "target_id": "canary-latency", "summary": "Expansion waits on p95 recovery.", "priority": 0.94},
      {"id": "visual-rollback", "label": "Rollback ready", "target_id": "rollback", "summary": "Rollback path is prepared.", "priority": 0.78}
    ]
  }
}
