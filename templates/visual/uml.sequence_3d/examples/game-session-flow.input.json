{
  "schema": "efp.visual.input.uml.sequence.v1",
  "title": "Game Session Flow Sequence",
  "participants": [
    {
      "id": "browser",
      "label": "Player Browser",
      "display_name": "Player Browser",
      "subtitle": "user session",
      "kind": "actor",
      "lane_index": 0,
      "depth": -0.6,
      "color": "#63a9ff",
      "summary": "Starts and observes the match"
    },
    {
      "id": "view",
      "label": "Game View",
      "display_name": "Game View",
      "subtitle": "screen",
      "kind": "boundary",
      "lane_index": 1,
      "depth": -0.35,
      "color": "#a77cff",
      "summary": "Renders board and player actions"
    },
    {
      "id": "controller",
      "label": "SampleViewController",
      "display_name": "SampleViewController",
      "subtitle": "UI orchestration",
      "kind": "controller",
      "lane_index": 2,
      "depth": -0.1,
      "color": "#ee6b73",
      "summary": "Coordinates setup and UI callbacks"
    },
    {
      "id": "engine",
      "label": "GameEngine",
      "display_name": "GameEngine",
      "subtitle": "rules engine",
      "kind": "service",
      "lane_index": 3,
      "depth": 0.15,
      "color": "#35c2a1",
      "summary": "Applies rules and advances turns"
    },
    {
      "id": "timer",
      "label": "TTTManager",
      "display_name": "TTTManager",
      "subtitle": "timer/session monitor",
      "kind": "manager",
      "lane_index": 4,
      "depth": 0.35,
      "color": "#47c477",
      "summary": "Tracks session time and completion state"
    },
    {
      "id": "api",
      "label": "Game API",
      "display_name": "Game API",
      "subtitle": "score service",
      "kind": "api",
      "lane_index": 5,
      "depth": 0.55,
      "color": "#e5a84c",
      "summary": "Persists score and session result"
    },
    {
      "id": "audit",
      "label": "Audit Stream",
      "display_name": "Audit Stream",
      "subtitle": "event log",
      "kind": "event_stream",
      "lane_index": 6,
      "depth": 0.75,
      "color": "#b6c2d9",
      "summary": "Records visible result events"
    }
  ],
  "phases": [
    {
      "id": "receive",
      "label": "Receive",
      "status": "running",
      "color": "#63a9ff"
    },
    {
      "id": "setup",
      "label": "Setup",
      "status": "running",
      "color": "#a77cff"
    },
    {
      "id": "starting",
      "label": "Starting",
      "status": "warning",
      "color": "#e5a84c"
    },
    {
      "id": "session",
      "label": "Session Running",
      "status": "running",
      "color": "#47c477"
    },
    {
      "id": "finish",
      "label": "Finish Result",
      "status": "success",
      "color": "#ee6b73"
    },
    {
      "id": "cleanup",
      "label": "Cleanup",
      "status": "success",
      "color": "#b6c2d9"
    }
  ],
  "messages": [
    {
      "id": "m1",
      "order": 1,
      "from": "browser",
      "to": "view",
      "label": "tap Start Game",
      "kind": "sync",
      "phase": "receive",
      "status": "running",
      "curve": "arc",
      "importance": 0.92,
      "labelPriority": "important",
      "summary": "Player starts a new game session."
    },
    {
      "id": "m2",
      "order": 2,
      "from": "view",
      "to": "controller",
      "label": "startSession()",
      "kind": "sync",
      "phase": "receive",
      "status": "running",
      "curve": "arc",
      "importance": 0.86,
      "labelPriority": "important",
      "summary": "The screen delegates setup to the controller."
    },
    {
      "id": "m3",
      "order": 3,
      "from": "controller",
      "to": "engine",
      "label": "createBoard(size)",
      "kind": "sync",
      "phase": "setup",
      "status": "running",
      "curve": "arc",
      "importance": 0.72,
      "labelPriority": "normal",
      "summary": "Controller creates the board model."
    },
    {
      "id": "m4",
      "order": 4,
      "from": "engine",
      "to": "controller",
      "label": "board ready",
      "kind": "return",
      "phase": "setup",
      "status": "running",
      "curve": "return",
      "importance": 0.34,
      "labelPriority": "hover",
      "summary": "Board initialization returns to UI orchestration."
    },
    {
      "id": "m5",
      "order": 5,
      "from": "controller",
      "to": "timer",
      "label": "beginTimer()",
      "kind": "sync",
      "phase": "starting",
      "status": "running",
      "curve": "high_arc",
      "importance": 0.9,
      "labelPriority": "always",
      "summary": "Session timer starts and becomes a central monitor."
    },
    {
      "id": "m6",
      "order": 6,
      "from": "timer",
      "to": "engine",
      "label": "tick interval",
      "kind": "async",
      "phase": "session",
      "status": "running",
      "curve": "loop",
      "importance": 0.88,
      "labelPriority": "important",
      "summary": "Timer begins repeated game tick checks."
    },
    {
      "id": "m7",
      "order": 7,
      "from": "controller",
      "to": "view",
      "label": "renderBoard()",
      "kind": "sync",
      "phase": "starting",
      "status": "running",
      "curve": "arc",
      "importance": 0.64,
      "labelPriority": "normal",
      "summary": "Initial board is rendered."
    },
    {
      "id": "m8",
      "order": 8,
      "from": "browser",
      "to": "view",
      "label": "place mark A1",
      "kind": "sync",
      "phase": "session",
      "status": "running",
      "curve": "arc",
      "importance": 0.72,
      "labelPriority": "important",
      "summary": "Player marks the first cell."
    },
    {
      "id": "m9",
      "order": 9,
      "from": "view",
      "to": "controller",
      "label": "onCellSelected(A1)",
      "kind": "sync",
      "phase": "session",
      "status": "running",
      "curve": "arc",
      "importance": 0.44,
      "labelPriority": "hover",
      "summary": "UI sends selection callback."
    },
    {
      "id": "m10",
      "order": 10,
      "from": "controller",
      "to": "engine",
      "label": "applyMove(A1)",
      "kind": "sync",
      "phase": "session",
      "status": "running",
      "curve": "arc",
      "importance": 0.62,
      "labelPriority": "normal",
      "summary": "Controller asks engine to apply the move."
    },
    {
      "id": "m11",
      "order": 11,
      "from": "engine",
      "to": "engine",
      "label": "checkWinner()",
      "kind": "self",
      "phase": "session",
      "status": "running",
      "curve": "self",
      "importance": 0.7,
      "labelPriority": "normal",
      "summary": "Engine checks board state internally."
    },
    {
      "id": "m12",
      "order": 12,
      "from": "engine",
      "to": "timer",
      "label": "isComplete=false",
      "kind": "return",
      "phase": "session",
      "status": "running",
      "curve": "return",
      "importance": 0.32,
      "labelPriority": "hover",
      "summary": "Engine reports session is still running."
    },
    {
      "id": "m13",
      "order": 13,
      "from": "timer",
      "to": "controller",
      "label": "updateClock()",
      "kind": "async",
      "phase": "session",
      "status": "running",
      "curve": "arc",
      "importance": 0.58,
      "labelPriority": "normal",
      "summary": "Timer updates visible countdown."
    },
    {
      "id": "m14",
      "order": 14,
      "from": "browser",
      "to": "view",
      "label": "place mark B2",
      "kind": "sync",
      "phase": "session",
      "status": "running",
      "curve": "arc",
      "importance": 0.72,
      "labelPriority": "important",
      "summary": "Second action creates a result opportunity."
    },
    {
      "id": "m15",
      "order": 15,
      "from": "controller",
      "to": "engine",
      "label": "applyMove(B2)",
      "kind": "sync",
      "phase": "session",
      "status": "running",
      "curve": "arc",
      "importance": 0.52,
      "labelPriority": "hover",
      "summary": "Second move reaches the engine."
    },
    {
      "id": "m16",
      "order": 16,
      "from": "engine",
      "to": "engine",
      "label": "resolveResult()",
      "kind": "self",
      "phase": "finish",
      "status": "success",
      "curve": "self",
      "importance": 0.86,
      "labelPriority": "important",
      "summary": "Engine resolves winner or draw."
    },
    {
      "id": "m17",
      "order": 17,
      "from": "engine",
      "to": "timer",
      "label": "isComplete=true",
      "kind": "return",
      "phase": "finish",
      "status": "success",
      "curve": "return",
      "importance": 0.78,
      "labelPriority": "important",
      "summary": "Timer receives completion signal."
    },
    {
      "id": "m18",
      "order": 18,
      "from": "timer",
      "to": "api",
      "label": "updateScore(A/B)",
      "kind": "async",
      "phase": "finish",
      "status": "success",
      "curve": "high_arc",
      "importance": 0.94,
      "labelPriority": "always",
      "summary": "Final score is sent to persistence API."
    },
    {
      "id": "m19",
      "order": 19,
      "from": "api",
      "to": "audit",
      "label": "emit game.finished",
      "kind": "async",
      "phase": "finish",
      "status": "success",
      "curve": "arc",
      "importance": 0.55,
      "labelPriority": "hover",
      "summary": "Completion is recorded for observability."
    },
    {
      "id": "m20",
      "order": 20,
      "from": "api",
      "to": "timer",
      "label": "score persisted",
      "kind": "return",
      "phase": "cleanup",
      "status": "success",
      "curve": "return",
      "importance": 0.62,
      "labelPriority": "normal",
      "summary": "API confirms persistence."
    },
    {
      "id": "m21",
      "order": 21,
      "from": "timer",
      "to": "controller",
      "label": "finishAndReset()",
      "kind": "async",
      "phase": "cleanup",
      "status": "success",
      "curve": "arc",
      "importance": 0.84,
      "labelPriority": "important",
      "summary": "Timer asks controller to finalize UI state."
    },
    {
      "id": "m22",
      "order": 22,
      "from": "controller",
      "to": "view",
      "label": "showResultBanner()",
      "kind": "sync",
      "phase": "cleanup",
      "status": "success",
      "curve": "arc",
      "importance": 0.88,
      "labelPriority": "important",
      "summary": "User sees the final result banner."
    }
  ],
  "activations": [
    {
      "id": "act-view",
      "participant_id": "view",
      "start_order": 1,
      "end_order": 22,
      "label": "screen active"
    },
    {
      "id": "act-engine",
      "participant_id": "engine",
      "start_order": 4,
      "end_order": 18,
      "label": "rules engine active"
    },
    {
      "id": "act-timer",
      "participant_id": "timer",
      "start_order": 6,
      "end_order": 20,
      "label": "session timer active"
    },
    {
      "id": "act-api",
      "participant_id": "api",
      "start_order": 14,
      "end_order": 19,
      "label": "result persistence"
    }
  ],
  "fragments": [
    {
      "id": "frag-loop",
      "kind": "loop",
      "label": "game ticks",
      "condition": "until board is complete or timeout",
      "start_order": 8,
      "end_order": 13,
      "summary": "Repeated turn/timer updates are represented as one loop region."
    },
    {
      "id": "frag-alt",
      "kind": "alt",
      "label": "win or draw",
      "condition": "winner found vs board filled",
      "start_order": 14,
      "end_order": 18,
      "summary": "Result handling splits into score update or draw notification."
    }
  ],
  "visual": {
    "goal": "Explain the game session lifecycle from player action to running ticks and final score persistence.",
    "audience": "engineer reviewing runtime flow",
    "initial_focus_ids": [
      "browser",
      "controller",
      "engine",
      "timer",
      "api",
      "m1",
      "m6",
      "m14",
      "m18",
      "m21"
    ],
    "hidden_detail_ids": [
      "m4",
      "m9",
      "m10",
      "m12",
      "m15",
      "m19"
    ],
    "narrative_steps": [
      {
        "id": "overview",
        "title": "Start with lifelines",
        "summary": "Show browser, controller, engine, timer, and API as the main story actors.",
        "focus_ids": [
          "browser",
          "controller",
          "engine",
          "timer",
          "api"
        ]
      },
      {
        "id": "session",
        "title": "Follow the running loop",
        "summary": "Explain how ticks and score checks repeat without expanding every low-level call.",
        "focus_ids": [
          "m6",
          "frag-loop",
          "timer"
        ]
      },
      {
        "id": "result",
        "title": "Finish and persist",
        "summary": "Show final result, score update, and cleanup.",
        "focus_ids": [
          "m14",
          "m18",
          "m21"
        ]
      }
    ],
    "annotations": [
      {
        "id": "note-start",
        "target_id": "m1",
        "label": "Player entry",
        "summary": "The visible user action begins the sequence.",
        "priority": 1.0
      },
      {
        "id": "note-loop",
        "target_id": "frag-loop",
        "label": "Loop compressed",
        "summary": "Repeated ticks are summarized as a loop fragment instead of many duplicate messages.",
        "priority": 0.92
      },
      {
        "id": "note-score",
        "target_id": "m18",
        "label": "User-visible result",
        "summary": "Score persistence and completion state are the final result path.",
        "priority": 0.96
      }
    ]
  },
  "view": {
    "mode": "overview",
    "labelMode": "overview",
    "focusMode": "path",
    "cameraPreset": "left_to_right"
  },
  "renderHints": {
    "density": "normal",
    "routeStrategy": "arc",
    "showLegend": true,
    "showAnnotations": true
  }
}
