{
  "schema": "efp.visual.input.studio.v1",
  "title": "Game Session Walkthrough Studio",
  "goal": "Explain the player session start flow.",
  "audience": "gameplay engineer",
  "assumptions": ["The example focuses on happy-path session start."],
  "hero": {
    "type": "sequence",
    "title": "Session Start Walkthrough",
    "summary": "Client, matchmaking, session service, and event stream.",
    "data": {
      "participants": [
        {"id": "player", "label": "Player", "kind": "user", "provider": "aws", "service": "cloudfront", "platform": "aws", "status": "ok", "importance": 0.78, "summary": "Player starts a session.", "presentation": {"shape": "actor_card", "icon": "generic.user", "color": "#e5a84c"}},
        {"id": "matchmaker", "label": "Matchmaker", "kind": "service", "provider": "aws", "service": "lambda", "platform": "aws", "status": "ok", "importance": 0.9, "summary": "Allocates a match.", "presentation": {"shape": "service_box", "icon": "aws.lambda", "color": "#22c55e"}},
        {"id": "events", "label": "Session Events", "kind": "event_stream", "provider": "aws", "service": "eventbridge", "platform": "aws", "status": "ok", "importance": 0.74, "summary": "Publishes session lifecycle.", "presentation": {"shape": "event_bus", "icon": "aws.eventbridge", "color": "#a78bfa"}}
      ],
      "messages": [
        {"id": "msg-start", "from": "player", "to": "matchmaker", "kind": "calls", "label": "start", "phase": "match", "directed": true, "importance": 0.88, "summary": "Player requests a session.", "presentation": {"arrow": "forward", "lineStyle": "solid", "flow": true}},
        {"id": "msg-event", "from": "matchmaker", "to": "events", "kind": "emits", "label": "session.started", "phase": "publish", "directed": true, "importance": 0.8, "summary": "Matchmaker publishes start event.", "presentation": {"arrow": "forward", "lineStyle": "dashed", "flow": true}}
      ],
      "events": [
        {"id": "session-started", "label": "Session started", "kind": "event", "status": "success", "summary": "Session accepted and published.", "presentation": {"shape": "event_bus", "icon": "aws.eventbridge", "color": "#22c55e"}}
      ]
    }
  },
  "navigation": [{"id": "nav-flow", "label": "Flow", "target_id": "flow-panel", "icon": "generic.pipeline", "summary": "Walkthrough panel."}],
  "panels": [
    {"id": "overview-panel", "type": "overview", "title": "Walkthrough Overview", "target_refs": ["player", "matchmaker", "events"], "summary": "The player starts a session and the matchmaker publishes an event.", "items": [{"label": "phase", "value": "match"}], "metrics": [{"label": "messages", "value": "2"}], "evidence": [{"label": "trace", "source": "session-trace"}], "content": {"expected_result": "session accepted"}, "presentation": {"shape": "service_box", "icon": "generic.pipeline"}},
    {"id": "flow-panel", "type": "phase", "title": "Start And Publish", "target_refs": ["msg-start", "msg-event", "session-started"], "summary": "Two directed messages create and announce the session.", "items": [{"label": "1", "value": "start"}, {"label": "2", "value": "session.started"}], "metrics": [{"label": "latency", "value": "180ms"}], "evidence": [{"label": "trace", "source": "otel"}], "content": {"phase": "match"}, "presentation": {"shape": "diamond", "icon": "generic.decision"}}
  ],
  "controls": [
    {"id": "step-match", "label": "Step match", "type": "step", "target": "msg-start", "action": "next"},
    {"id": "focus-events", "label": "Focus events", "type": "focus", "target": "events", "action": "focus"}
  ],
  "annotations": [{"id": "anno-event", "label": "Published", "target_id": "events", "summary": "Session lifecycle leaves the service."}],
  "view": {"colorBy": "provider", "mode": "overview"},
  "renderHints": {"showLegend": true, "palette": "cloud_provider", "iconMode": "billboard", "colorBy": "provider"},
  "visual": {
    "goal": "Start with the player to matchmaker message.",
    "initial_focus_ids": ["player", "matchmaker", "msg-start", "flow-panel"],
    "hidden_detail_ids": ["msg-event"],
    "narrative_steps": [{"id": "start", "title": "Start session", "summary": "Player starts a session and matchmaker publishes an event.", "focus_ids": ["player", "matchmaker", "events"]}],
    "annotations": [{"id": "visual-event", "label": "Event", "target_id": "events", "summary": "Session event is published.", "priority": 0.82}]
  }
}
