{
  "schema": "efp.visual.input.studio.v1",
  "title": "Checkout Release Studio",
  "goal": "Show whether the checkout release can continue.",
  "audience": "release reviewer",
  "assumptions": ["Canary metrics and CI evidence are from the same release candidate."],
  "hero": {
    "type": "pipeline",
    "title": "Checkout Release Path",
    "summary": "Build, canary, and approval gates for the release.",
    "data": {
      "nodes": [
        {
          "id": "build",
          "label": "Build",
          "kind": "job",
          "provider": "jenkins",
          "service": "jenkins",
          "platform": "jenkins",
          "status": "success",
          "importance": 0.92,
          "summary": "Build and tests passed.",
          "presentation": {"shape": "ci_card", "icon": "jenkins", "color": "#60a5fa"}
        },
        {
          "id": "canary",
          "label": "Canary",
          "kind": "service",
          "provider": "aws",
          "service": "lambda",
          "platform": "aws",
          "status": "warning",
          "importance": 0.88,
          "summary": "Canary has elevated latency.",
          "presentation": {"shape": "service_box", "icon": "aws.lambda", "color": "#f59e0b"}
        },
        {
          "id": "approval",
          "label": "Approval",
          "kind": "decision",
          "provider": "aws",
          "service": "cloudwatch",
          "platform": "aws",
          "status": "blocked",
          "importance": 0.78,
          "summary": "Approval waits on canary recovery.",
          "presentation": {"shape": "diamond", "icon": "generic.decision", "color": "#fb7185"}
        }
      ],
      "edges": [
        {
          "id": "build-to-canary",
          "from": "build",
          "to": "canary",
          "kind": "deploys",
          "label": "deploys",
          "directed": true,
          "importance": 0.84,
          "summary": "Build artifact deploys to canary.",
          "presentation": {"arrow": "forward", "lineStyle": "solid", "flow": true}
        },
        {
          "id": "canary-to-approval",
          "from": "canary",
          "to": "approval",
          "kind": "validates",
          "label": "gates",
          "directed": true,
          "importance": 0.8,
          "summary": "Canary health gates approval.",
          "presentation": {"arrow": "forward", "lineStyle": "dashed", "flow": true}
        }
      ],
      "events": [
        {"id": "latency-spike", "label": "Latency spike", "kind": "risk", "status": "warning", "summary": "P95 moved above target.", "presentation": {"shape": "warning_prism", "icon": "generic.warning", "color": "#f59e0b"}}
      ]
    }
  },
  "navigation": [
    {"id": "nav-overview", "label": "Overview", "target_id": "overview-panel", "icon": "generic.pipeline", "summary": "Release state."},
    {"id": "nav-gate", "label": "Canary", "target_id": "canary-panel", "icon": "generic.decision", "summary": "Gate detail."}
  ],
  "panels": [
    {
      "id": "overview-panel",
      "type": "detail",
      "title": "Release Readiness",
      "target_refs": ["build", "canary", "approval"],
      "summary": "Build is clear, canary is under watch, and approval is blocked.",
      "items": [{"label": "Current phase", "value": "canary"}],
      "metrics": [{"label": "passed checks", "value": "18/20"}],
      "evidence": [{"label": "CI run", "source": "jenkins"}],
      "content": {"status": "watch", "next_action": "Wait for latency recovery before expansion."},
      "presentation": {"shape": "service_box", "icon": "generic.pipeline"}
    },
    {
      "id": "canary-panel",
      "type": "gate",
      "title": "Canary Gate",
      "target_refs": ["canary", "canary-to-approval", "latency-spike"],
      "summary": "Canary latency is the release risk.",
      "metrics": [{"label": "latency p95", "value": "410ms"}],
      "evidence": [{"label": "CloudWatch alarm", "source": "cloudwatch"}],
      "content": {"owner": "release engineering", "next_action": "Hold approval."},
      "presentation": {"shape": "warning_prism", "icon": "generic.warning"}
    }
  ],
  "controls": [
    {"id": "focus-canary", "label": "Focus canary", "type": "focus", "target": "canary", "action": "focus"},
    {"id": "filter-warning", "label": "Warnings", "type": "filter", "target": "status", "action": "warning"}
  ],
  "annotations": [
    {"id": "anno-canary", "label": "Watch", "target_id": "canary", "summary": "Canary latency blocks approval."}
  ],
  "view": {"colorBy": "provider", "mode": "overview"},
  "renderHints": {"showLegend": true, "palette": "cloud_provider", "iconMode": "billboard", "colorBy": "provider"},
  "visual": {
    "goal": "Start with the canary gate.",
    "initial_focus_ids": ["build", "canary", "approval", "overview-panel"],
    "hidden_detail_ids": ["build-to-canary"],
    "narrative_steps": [
      {"id": "overview", "title": "Check readiness", "summary": "Build passed but approval depends on canary.", "focus_ids": ["build", "canary", "approval"]},
      {"id": "risk", "title": "Inspect latency", "summary": "Latency spike explains the blocked gate.", "focus_ids": ["canary", "latency-spike", "canary-panel"]}
    ],
    "annotations": [
      {"id": "visual-canary", "label": "Canary risk", "target_id": "canary", "summary": "Latency is above target.", "priority": 0.92}
    ]
  }
}
