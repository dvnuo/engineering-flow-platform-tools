{
  "schema": "efp.visual.template_input_schema.v1",
  "template_id": "codebase.galaxy",
  "input_schema_kind": "graph_v1",
  "json_schema": {
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "efp.visual.input.graph.v1",
    "title": "EFP Visual Graph Input v1",
    "description": "Graph input for offline visual templates.",
    "type": "object",
    "required": [
      "nodes"
    ],
    "additionalProperties": true,
    "properties": {
      "schema": {
        "type": "string",
        "const": "efp.visual.input.graph.v1"
      },
      "title": {
        "type": "string"
      },
      "nodes": {
        "type": "array",
        "items": {
          "$ref": "#/$defs/node"
        }
      },
      "edges": {
        "type": "array",
        "items": {
          "$ref": "#/$defs/edge"
        }
      }
    },
    "$defs": {
      "object": {
        "type": "object",
        "additionalProperties": true
      },
      "node": {
        "type": "object",
        "required": [
          "id"
        ],
        "additionalProperties": true,
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "label": {
            "type": "string"
          },
          "kind": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "group": {
            "type": "string"
          },
          "metadata": {
            "$ref": "#/$defs/object"
          },
          "metrics": {
            "$ref": "#/$defs/object"
          }
        }
      },
      "edge": {
        "type": "object",
        "required": [
          "from",
          "to"
        ],
        "additionalProperties": true,
        "properties": {
          "from": {
            "type": "string",
            "minLength": 1
          },
          "to": {
            "type": "string",
            "minLength": 1
          },
          "kind": {
            "type": "string"
          },
          "label": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "weight": {
            "type": "number"
          },
          "metadata": {
            "$ref": "#/$defs/object"
          }
        }
      }
    }
  },
  "example": {
    "schema": "efp.visual.input.graph.v1",
    "title": "Codebase Galaxy",
    "nodes": [
      {
        "id": "cmd",
        "label": "cmd",
        "kind": "directory",
        "status": "success",
        "group": "root"
      },
      {
        "id": "internal",
        "label": "internal",
        "kind": "directory",
        "status": "success",
        "group": "root"
      },
      {
        "id": "visual_commands",
        "label": "visual commands",
        "kind": "module",
        "status": "success",
        "group": "visual"
      },
      {
        "id": "visual_render",
        "label": "visual render",
        "kind": "module",
        "status": "success",
        "group": "visual"
      },
      {
        "id": "output",
        "label": "output",
        "kind": "module",
        "status": "info",
        "group": "shared"
      }
    ],
    "edges": [
      {
        "from": "cmd",
        "to": "visual_commands",
        "kind": "imports"
      },
      {
        "from": "visual_commands",
        "to": "visual_render",
        "kind": "calls"
      },
      {
        "from": "visual_commands",
        "to": "output",
        "kind": "uses"
      },
      {
        "from": "internal",
        "to": "visual_render",
        "kind": "contains"
      }
    ]
  }
}
