{
  "schema": "efp.visual.template_input_schema.v1",
  "template_id": "service.topology",
  "input_schema_kind": "graph_v1",
  "json_schema": {
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "efp.visual.input.graph.v1",
    "title": "EFP Visual Graph Input v1",
    "description": "Graph input for offline visual templates.",
    "type": "object",
    "required": [
      "nodes"
    ],
    "additionalProperties": true,
    "properties": {
      "schema": {
        "type": "string",
        "const": "efp.visual.input.graph.v1"
      },
      "title": {
        "type": "string"
      },
      "nodes": {
        "type": "array",
        "items": {
          "$ref": "#/$defs/node"
        }
      },
      "edges": {
        "type": "array",
        "items": {
          "$ref": "#/$defs/edge"
        }
      }
    },
    "$defs": {
      "object": {
        "type": "object",
        "additionalProperties": true
      },
      "node": {
        "type": "object",
        "required": [
          "id"
        ],
        "additionalProperties": true,
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "label": {
            "type": "string"
          },
          "kind": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "group": {
            "type": "string"
          },
          "metadata": {
            "$ref": "#/$defs/object"
          },
          "metrics": {
            "$ref": "#/$defs/object"
          }
        }
      },
      "edge": {
        "type": "object",
        "required": [
          "from",
          "to"
        ],
        "additionalProperties": true,
        "properties": {
          "from": {
            "type": "string",
            "minLength": 1
          },
          "to": {
            "type": "string",
            "minLength": 1
          },
          "kind": {
            "type": "string"
          },
          "label": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "weight": {
            "type": "number"
          },
          "metadata": {
            "$ref": "#/$defs/object"
          }
        }
      }
    }
  },
  "example": {
    "schema": "efp.visual.input.graph.v1",
    "title": "Service Topology",
    "nodes": [
      {
        "id": "frontend",
        "label": "Frontend",
        "kind": "web",
        "status": "success"
      },
      {
        "id": "backend",
        "label": "Backend API",
        "kind": "api",
        "status": "success"
      },
      {
        "id": "database",
        "label": "Database",
        "kind": "db",
        "status": "warning"
      },
      {
        "id": "cache",
        "label": "Cache",
        "kind": "infra",
        "status": "success"
      },
      {
        "id": "external_api",
        "label": "External API",
        "kind": "external",
        "status": "info"
      }
    ],
    "edges": [
      {
        "from": "frontend",
        "to": "backend",
        "kind": "request"
      },
      {
        "from": "backend",
        "to": "database",
        "kind": "query"
      },
      {
        "from": "backend",
        "to": "cache",
        "kind": "cache"
      },
      {
        "from": "backend",
        "to": "external_api",
        "kind": "integration"
      }
    ]
  }
}
