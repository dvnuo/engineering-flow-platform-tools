{
  "schema": "efp.visual.template_input_schema.v1",
  "template_id": "agent.permission_gate",
  "input_schema_kind": "graph_events_v1",
  "json_schema": {
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "efp.visual.input.graph_events.v1",
    "title": "EFP Visual Graph Events Input v1",
    "description": "Graph input with optional event stream for offline visual templates.",
    "type": "object",
    "required": [
      "nodes"
    ],
    "additionalProperties": true,
    "properties": {
      "schema": {
        "type": "string",
        "const": "efp.visual.input.graph_events.v1"
      },
      "title": {
        "type": "string"
      },
      "nodes": {
        "type": "array",
        "items": {
          "$ref": "#/$defs/node"
        }
      },
      "edges": {
        "type": "array",
        "items": {
          "$ref": "#/$defs/edge"
        }
      },
      "events": {
        "type": "array",
        "items": {
          "$ref": "#/$defs/event"
        }
      }
    },
    "$defs": {
      "object": {
        "type": "object",
        "additionalProperties": true
      },
      "node": {
        "type": "object",
        "required": [
          "id"
        ],
        "additionalProperties": true,
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "label": {
            "type": "string"
          },
          "kind": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "group": {
            "type": "string"
          },
          "metadata": {
            "$ref": "#/$defs/object"
          },
          "metrics": {
            "$ref": "#/$defs/object"
          }
        }
      },
      "edge": {
        "type": "object",
        "required": [
          "from",
          "to"
        ],
        "additionalProperties": true,
        "properties": {
          "from": {
            "type": "string",
            "minLength": 1
          },
          "to": {
            "type": "string",
            "minLength": 1
          },
          "kind": {
            "type": "string"
          },
          "label": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "weight": {
            "type": "number"
          },
          "metadata": {
            "$ref": "#/$defs/object"
          }
        }
      },
      "event": {
        "type": "object",
        "required": [
          "id"
        ],
        "additionalProperties": true,
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "time": {
            "type": "string",
            "format": "date-time"
          },
          "kind": {
            "type": "string"
          },
          "node_id": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "label": {
            "type": "string"
          },
          "summary": {
            "type": "string"
          },
          "payload": {
            "$ref": "#/$defs/object"
          }
        }
      }
    }
  },
  "example": {
    "schema": "efp.visual.input.graph_events.v1",
    "title": "Permission Gate",
    "nodes": [
      {
        "id": "request",
        "label": "Action request",
        "kind": "input",
        "status": "info"
      },
      {
        "id": "policy",
        "label": "Policy check",
        "kind": "policy",
        "status": "success"
      },
      {
        "id": "allow",
        "label": "Allow",
        "kind": "gate",
        "status": "success"
      },
      {
        "id": "ask",
        "label": "Ask user",
        "kind": "gate",
        "status": "warning"
      },
      {
        "id": "deny",
        "label": "Deny",
        "kind": "gate",
        "status": "error"
      },
      {
        "id": "command",
        "label": "Command",
        "kind": "tool",
        "status": "success"
      }
    ],
    "edges": [
      {
        "from": "request",
        "to": "policy",
        "kind": "evaluate"
      },
      {
        "from": "policy",
        "to": "allow",
        "kind": "safe"
      },
      {
        "from": "policy",
        "to": "ask",
        "kind": "needs_user"
      },
      {
        "from": "policy",
        "to": "deny",
        "kind": "blocked"
      },
      {
        "from": "allow",
        "to": "command",
        "kind": "execute"
      }
    ],
    "events": [
      {
        "id": "p1",
        "time": "2026-06-03T13:20:00Z",
        "kind": "gate",
        "node_id": "policy",
        "summary": "Policy evaluated."
      },
      {
        "id": "p2",
        "time": "2026-06-03T13:21:00Z",
        "kind": "allow",
        "node_id": "allow",
        "summary": "Read-only command allowed."
      },
      {
        "id": "p3",
        "time": "2026-06-03T13:22:00Z",
        "kind": "ask",
        "node_id": "ask",
        "summary": "Write command would ask."
      },
      {
        "id": "p4",
        "time": "2026-06-03T13:23:00Z",
        "kind": "deny",
        "node_id": "deny",
        "summary": "Unsafe operation denied."
      }
    ]
  }
}
