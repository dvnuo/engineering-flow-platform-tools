      {"id": "risk", "title": "Review queue risk", "summary": "Queue age is the operating risk.", "focus_ids": ["queue", "queue-age", "queue-panel"]}
    ],
    "annotations": [
      {"id": "visual-core", "label": "Core service", "target_id": "orders", "summary": "Orders owns orchestration.", "priority": 0.92},
      {"id": "visual-risk", "label": "Queue risk", "target_id": "queue", "summary": "Fulfillment delay risk.", "priority": 0.86}
    ]
  }
