{
  "schema": "efp.visual.template_input_schema.v1",
  "template_id": "runtime.topology",
  "input_schema_kind": "graph_v1",
  "json_schema": {
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "efp.visual.input.graph.v1",
    "title": "EFP Visual Graph Input v1",
    "description": "Graph input for offline visual templates.",
    "type": "object",
    "required": [
      "nodes"
    ],
    "additionalProperties": true,
    "properties": {
      "schema": {
        "type": "string",
        "const": "efp.visual.input.graph.v1"
      },
      "title": {
        "type": "string"
      },
      "nodes": {
        "type": "array",
        "items": {
          "$ref": "#/$defs/node"
        }
      },
      "edges": {
        "type": "array",
        "items": {
          "$ref": "#/$defs/edge"
        }
      }
    },
    "$defs": {
      "object": {
        "type": "object",
        "additionalProperties": true
      },
      "node": {
        "type": "object",
        "required": [
          "id"
        ],
        "additionalProperties": true,
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "label": {
            "type": "string"
          },
          "kind": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "group": {
            "type": "string"
          },
          "metadata": {
            "$ref": "#/$defs/object"
          },
          "metrics": {
            "$ref": "#/$defs/object"
          }
        }
      },
      "edge": {
        "type": "object",
        "required": [
          "from",
          "to"
        ],
        "additionalProperties": true,
        "properties": {
          "from": {
            "type": "string",
            "minLength": 1
          },
          "to": {
            "type": "string",
            "minLength": 1
          },
          "kind": {
            "type": "string"
          },
          "label": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "weight": {
            "type": "number"
          },
          "metadata": {
            "$ref": "#/$defs/object"
          }
        }
      }
    }
  },
  "example": {
    "schema": "efp.visual.input.graph.v1",
    "title": "Runtime Topology",
    "nodes": [
      {
        "id": "portal",
        "label": "Portal",
        "kind": "ui",
        "status": "success",
        "group": "client"
      },
      {
        "id": "adapter",
        "label": "Runtime adapter",
        "kind": "service",
        "status": "success",
        "group": "runtime"
      },
      {
        "id": "opencode",
        "label": "OpenCode server",
        "kind": "server",
        "status": "success",
        "group": "runtime"
      },
      {
        "id": "tools",
        "label": "Tools",
        "kind": "tooling",
        "status": "info",
        "group": "workspace"
      },
      {
        "id": "workspace",
        "label": "Workspace",
        "kind": "filesystem",
        "status": "success",
        "group": "workspace"
      }
    ],
    "edges": [
      {
        "from": "portal",
        "to": "adapter",
        "kind": "proxy",
        "label": "runtime proxy"
      },
      {
        "from": "adapter",
        "to": "opencode",
        "kind": "api",
        "label": "session"
      },
      {
        "from": "opencode",
        "to": "tools",
        "kind": "tool"
      },
      {
        "from": "tools",
        "to": "workspace",
        "kind": "file"
      }
    ]
  }
}
