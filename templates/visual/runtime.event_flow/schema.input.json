{
  "schema": "efp.visual.template_input_schema.v1",
  "template_id": "runtime.event_flow",
  "input_schema_kind": "graph_events_v1",
  "json_schema": {
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "efp.visual.input.graph_events.v1",
    "title": "EFP Visual Graph Events Input v1",
    "description": "Graph input with optional event stream for offline visual templates.",
    "type": "object",
    "required": [
      "nodes"
    ],
    "additionalProperties": true,
    "properties": {
      "schema": {
        "type": "string",
        "const": "efp.visual.input.graph_events.v1"
      },
      "title": {
        "type": "string"
      },
      "nodes": {
        "type": "array",
        "items": {
          "$ref": "#/$defs/node"
        }
      },
      "edges": {
        "type": "array",
        "items": {
          "$ref": "#/$defs/edge"
        }
      },
      "events": {
        "type": "array",
        "items": {
          "$ref": "#/$defs/event"
        }
      }
    },
    "$defs": {
      "object": {
        "type": "object",
        "additionalProperties": true
      },
      "node": {
        "type": "object",
        "required": [
          "id"
        ],
        "additionalProperties": true,
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "label": {
            "type": "string"
          },
          "kind": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "group": {
            "type": "string"
          },
          "metadata": {
            "$ref": "#/$defs/object"
          },
          "metrics": {
            "$ref": "#/$defs/object"
          }
        }
      },
      "edge": {
        "type": "object",
        "required": [
          "from",
          "to"
        ],
        "additionalProperties": true,
        "properties": {
          "from": {
            "type": "string",
            "minLength": 1
          },
          "to": {
            "type": "string",
            "minLength": 1
          },
          "kind": {
            "type": "string"
          },
          "label": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "weight": {
            "type": "number"
          },
          "metadata": {
            "$ref": "#/$defs/object"
          }
        }
      },
      "event": {
        "type": "object",
        "required": [
          "id"
        ],
        "additionalProperties": true,
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "time": {
            "type": "string",
            "format": "date-time"
          },
          "kind": {
            "type": "string"
          },
          "node_id": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "label": {
            "type": "string"
          },
          "summary": {
            "type": "string"
          },
          "payload": {
            "$ref": "#/$defs/object"
          }
        }
      }
    }
  },
  "example": {
    "schema": "efp.visual.input.graph_events.v1",
    "title": "Runtime Event Flow",
    "nodes": [
      {
        "id": "client",
        "label": "Client",
        "kind": "client",
        "status": "success"
      },
      {
        "id": "event_sse",
        "label": "Event SSE",
        "kind": "stream",
        "status": "success"
      },
      {
        "id": "message_part",
        "label": "message.part.updated",
        "kind": "event",
        "status": "info"
      },
      {
        "id": "snapshot",
        "label": "Snapshot reconcile",
        "kind": "state",
        "status": "warning"
      },
      {
        "id": "view",
        "label": "Rendered view",
        "kind": "ui",
        "status": "success"
      }
    ],
    "edges": [
      {
        "from": "client",
        "to": "event_sse",
        "kind": "subscribe"
      },
      {
        "from": "event_sse",
        "to": "message_part",
        "kind": "emit"
      },
      {
        "from": "message_part",
        "to": "snapshot",
        "kind": "merge"
      },
      {
        "from": "snapshot",
        "to": "view",
        "kind": "paint"
      }
    ],
    "events": [
      {
        "id": "f1",
        "time": "2026-06-03T13:40:00Z",
        "kind": "event_open",
        "node_id": "event_sse",
        "summary": "SSE stream opened."
      },
      {
        "id": "f2",
        "time": "2026-06-03T13:41:00Z",
        "kind": "message.part.updated",
        "node_id": "message_part",
        "summary": "Message part updated."
      },
      {
        "id": "f3",
        "time": "2026-06-03T13:42:00Z",
        "kind": "snapshot",
        "node_id": "snapshot",
        "summary": "Snapshot reconciled."
      }
    ]
  }
}
