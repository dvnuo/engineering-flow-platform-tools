{
  "schema": "efp.visual.template_input_schema.v1",
  "template_id": "uml.component_deployment_3d",
  "input_schema_kind": "uml_component_deployment_v1",
  "json_schema": {
    "$schema": "json-schema-draft-2020-12",
    "type": "object",
    "required": [
      "schema",
      "components"
    ],
    "properties": {
      "schema": {
        "const": "efp.visual.input.uml.component_deployment.v1"
      },
      "title": {
        "type": "string"
      },
      "notes": {
        "type": "array",
        "items": {
          "type": "string"
        }
      },
      "deployments": {
        "type": "array",
        "items": {
          "type": "object",
          "required": [
            "id",
            "label"
          ],
          "properties": {
            "id": {
              "type": "string"
            },
            "label": {
              "type": "string"
            },
            "kind": {
              "type": "string"
            },
            "status": {
              "type": "string"
            },
            "metadata": {
              "type": "object"
            },
            "metrics": {
              "type": "object"
            }
          }
        }
      },
      "components": {
        "type": "array",
        "items": {
          "type": "object",
          "required": [
            "id",
            "label"
          ],
          "properties": {
            "id": {
              "type": "string"
            },
            "label": {
              "type": "string"
            },
            "kind": {
              "type": "string"
            },
            "deployment_id": {
              "type": "string"
            },
            "interfaces": {
              "type": "array"
            },
            "responsibilities": {
              "type": "array"
            },
            "status": {
              "type": "string"
            },
            "metadata": {
              "type": "object"
            },
            "metrics": {
              "type": "object"
            }
          }
        }
      },
      "links": {
        "type": "array",
        "items": {
          "type": "object",
          "required": [
            "from",
            "to"
          ],
          "properties": {
            "from": {
              "type": "string"
            },
            "to": {
              "type": "string"
            },
            "kind": {
              "type": "string"
            },
            "protocol": {
              "type": "string"
            },
            "label": {
              "type": "string"
            },
            "status": {
              "type": "string"
            },
            "metadata": {
              "type": "object"
            }
          }
        }
      }
    }
  },
  "example": {
    "schema": "efp.visual.input.uml.component_deployment.v1",
    "title": "Portal Runtime Deployment Components",
    "deployments": [
      {
        "id": "browser",
        "label": "User Browser",
        "kind": "client",
        "status": "success"
      },
      {
        "id": "portal-node",
        "label": "Portal Node",
        "kind": "server",
        "status": "success",
        "metrics": {
          "cpu": 0.42
        }
      },
      {
        "id": "runtime-vm",
        "label": "Runtime VM",
        "kind": "worker",
        "status": "warning"
      },
      {
        "id": "artifact-store",
        "label": "Artifact Store",
        "kind": "storage",
        "status": "success"
      }
    ],
    "components": [
      {
        "id": "portal-ui",
        "label": "Portal UI",
        "kind": "component",
        "deployment_id": "browser",
        "interfaces": [
          "artifact viewer"
        ],
        "responsibilities": [
          "render visual output"
        ],
        "status": "success"
      },
      {
        "id": "portal-api",
        "label": "Portal API",
        "kind": "component",
        "deployment_id": "portal-node",
        "interfaces": [
          "session proxy",
          "artifact proxy"
        ],
        "responsibilities": [
          "route visual artifacts"
        ],
        "status": "success"
      },
      {
        "id": "codex-runner",
        "label": "Codex Runner",
        "kind": "component",
        "deployment_id": "runtime-vm",
        "interfaces": [
          "command execution"
        ],
        "responsibilities": [
          "generate input json"
        ],
        "status": "warning"
      },
      {
        "id": "visual-cli",
        "label": "Visual CLI",
        "kind": "component",
        "deployment_id": "runtime-vm",
        "interfaces": [
          "render",
          "inspect-input",
          "doctor"
        ],
        "responsibilities": [
          "validate and render templates"
        ],
        "status": "success"
      },
      {
        "id": "static-artifact",
        "label": "Static Artifact",
        "kind": "component",
        "deployment_id": "artifact-store",
        "interfaces": [
          "index.html",
          "data.js"
        ],
        "responsibilities": [
          "offline visual output"
        ],
        "status": "success"
      }
    ],
    "links": [
      {
        "from": "browser",
        "to": "portal-api",
        "kind": "proxy",
        "protocol": "portal proxy",
        "label": "view artifact"
      },
      {
        "from": "portal-api",
        "to": "codex-runner",
        "kind": "control",
        "label": "start run"
      },
      {
        "from": "codex-runner",
        "to": "visual-cli",
        "kind": "exec",
        "label": "visual render"
      },
      {
        "from": "visual-cli",
        "to": "static-artifact",
        "kind": "writes",
        "label": "offline files"
      },
      {
        "from": "portal-api",
        "to": "static-artifact",
        "kind": "serves",
        "label": "relative static site"
      }
    ]
  }
}
