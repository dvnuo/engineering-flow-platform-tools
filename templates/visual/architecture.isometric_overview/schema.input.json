{
  "schema": "efp.visual.template_input_schema.v1",
  "template_id": "architecture.isometric_overview",
  "input_schema_kind": "isometric_architecture_v1",
  "json_schema": {
    "$schema": "json-schema-draft-2020-12",
    "$id": "efp.visual.input.isometric_architecture.v1",
    "title": "EFP Isometric Architecture Input",
    "type": "object",
    "additionalProperties": true,
    "required": [
      "schema",
      "title",
      "zones",
      "entities",
      "links"
    ],
    "properties": {
      "schema": {
        "const": "efp.visual.input.isometric_architecture.v1",
        "description": "Input contract identifier."
      },
      "title": {
        "type": "string",
        "minLength": 1,
        "description": "Short title shown in the renderer toolbar."
      },
      "subtitle": {
        "type": "string",
        "description": "Optional subtitle for scope, environment, or system boundary."
      },
      "goal": {
        "type": "string",
        "description": "What the viewer should understand from the first view."
      },
      "theme": {
        "type": "string",
        "enum": [
          "architecture_light"
        ],
        "default": "architecture_light"
      },
      "canvas": {
        "type": "object",
        "additionalProperties": true,
        "properties": {
          "grid": {
            "oneOf": [
              {
                "type": "boolean"
              },
              {
                "type": "object",
                "additionalProperties": true,
                "properties": {
                  "enabled": {
                    "type": "boolean",
                    "default": true
                  },
                  "step": {
                    "type": "number",
                    "exclusiveMinimum": 0,
                    "default": 1
                  },
                  "subdivisions": {
                    "type": "integer",
                    "minimum": 1,
                    "default": 4
                  }
                }
              }
            ],
            "description": "Enable or configure the isometric base grid."
          },
          "padding": {
            "type": "number",
            "minimum": 0,
            "default": 2
          }
        }
      },
      "camera": {
        "type": "object",
        "additionalProperties": true,
        "properties": {
          "mode": {
            "type": "string",
            "enum": [
              "orthographic_isometric"
            ],
            "default": "orthographic_isometric"
          },
          "position": {
            "$ref": "#/$defs/vector3"
          },
          "target": {
            "$ref": "#/$defs/vector3"
          },
          "zoom": {
            "type": "number",
            "exclusiveMinimum": 0
          },
          "constrainedOrbit": {
            "type": "boolean",
            "default": true
          }
        }
      },
      "zones": {
        "type": "array",
        "minItems": 1,
        "items": {
          "$ref": "#/$defs/zone"
        },
        "description": "Bounded architecture areas such as client, edge, gateway, service, cache, database, storage, observability, or admin zones."
      },
      "entities": {
        "type": "array",
        "minItems": 1,
        "items": {
          "$ref": "#/$defs/entity"
        },
        "description": "Typed architecture objects rendered with kind-specific 3D geometry."
      },
      "links": {
        "type": "array",
        "items": {
          "$ref": "#/$defs/link"
        },
        "description": "Directional architecture relationships rendered as thick arrows."
      },
      "annotations": {
        "type": "array",
        "items": {
          "$ref": "#/$defs/annotation"
        }
      },
      "legend": {
        "type": "object",
        "additionalProperties": true,
        "properties": {
          "items": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": true,
              "properties": {
                "id": {
                  "type": "string"
                },
                "label": {
                  "type": "string"
                },
                "kind": {
                  "type": "string"
                },
                "color": {
                  "type": "string"
                }
              }
            }
          }
        }
      },
      "controls": {
        "type": "array",
        "items": {
          "type": "string",
          "enum": [
            "overview",
            "focus",
            "isolate",
            "hide_others",
            "show_all",
            "toggle_labels",
            "toggle_boundaries",
            "toggle_arrows",
            "reset_camera",
            "export_json"
          ]
        },
        "default": [
          "overview",
          "reset_camera",
          "focus",
          "isolate",
          "hide_others",
          "show_all",
          "toggle_labels",
          "toggle_boundaries",
          "toggle_arrows",
          "export_json"
        ]
      },
      "visual": {
        "type": "object",
        "additionalProperties": true,
        "properties": {
          "goal": {
            "type": "string"
          },
          "assumptions": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Assumptions made for placement, omitted detail, or inferred architecture behavior."
          },
          "initial_focus_ids": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "hidden_detail_ids": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "narrative_steps": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": true,
              "properties": {
                "id": {
                  "type": "string"
                },
                "title": {
                  "type": "string"
                },
                "focus_ids": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                }
              }
            }
          },
          "annotations": {
            "type": "array",
            "items": {
              "$ref": "#/$defs/annotation"
            }
          }
        }
      },
      "view": {
        "type": "object",
        "additionalProperties": true,
        "properties": {
          "labelMode": {
            "type": "string",
            "enum": [
              "always",
              "overview",
              "important",
              "hover",
              "hidden"
            ],
            "default": "overview"
          },
          "showBoundaries": {
            "type": "boolean",
            "default": true
          },
          "showArrows": {
            "type": "boolean",
            "default": true
          },
          "showLegend": {
            "type": "boolean",
            "default": true
          }
        }
      },
      "renderHints": {
        "type": "object",
        "additionalProperties": true,
        "properties": {
          "colorBy": {
            "type": "string",
            "enum": [
              "kind",
              "zone",
              "status",
              "platform",
              "provider"
            ]
          },
          "routeCollisionAvoidance": {
            "type": "string",
            "enum": [
              "basic",
              "explicit_only"
            ],
            "default": "basic"
          },
          "preferExplicitRoutes": {
            "type": "boolean",
            "default": true
          }
        }
      }
    },
    "$defs": {
      "vector3": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "x": {
            "type": "number"
          },
          "y": {
            "type": "number"
          },
          "z": {
            "type": "number"
          }
        }
      },
      "point2": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "x",
          "y"
        ],
        "properties": {
          "x": {
            "type": "number"
          },
          "y": {
            "type": "number"
          }
        }
      },
      "bounds": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "x",
          "y",
          "w",
          "h"
        ],
        "properties": {
          "x": {
            "type": "number"
          },
          "y": {
            "type": "number"
          },
          "w": {
            "type": "number",
            "exclusiveMinimum": 0
          },
          "h": {
            "type": "number",
            "exclusiveMinimum": 0
          }
        }
      },
      "presentation": {
        "type": "object",
        "additionalProperties": true,
        "properties": {
          "shape": {
            "type": "string"
          },
          "icon": {
            "type": "string"
          },
          "color": {
            "type": "string"
          },
          "arrow": {
            "type": "string",
            "enum": [
              "forward",
              "reverse",
              "none"
            ]
          },
          "boundary": {
            "type": "string",
            "enum": [
              "solid",
              "dashed",
              "dotted"
            ]
          },
          "lineStyle": {
            "type": "string",
            "enum": [
              "solid",
              "dashed",
              "dotted"
            ]
          },
          "label": {
            "oneOf": [
              {
                "type": "string",
                "enum": [
                  "top",
                  "inline",
                  "hidden"
                ]
              },
              {
                "type": "object",
                "additionalProperties": true
              }
            ]
          },
          "leaderLine": {
            "type": "boolean",
            "default": true
          }
        }
      },
      "zone": {
        "type": "object",
        "additionalProperties": true,
        "required": [
          "id",
          "label",
          "bounds"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "label": {
            "type": "string",
            "minLength": 1
          },
          "bounds": {
            "$ref": "#/$defs/bounds"
          },
          "kind": {
            "type": "string"
          },
          "style": {
            "type": "string",
            "enum": [
              "solid",
              "dashed",
              "dotted"
            ]
          },
          "color": {
            "type": "string"
          },
          "summary": {
            "type": "string"
          },
          "presentation": {
            "type": "object",
            "additionalProperties": true,
            "properties": {
              "lineStyle": {
                "type": "string",
                "enum": [
                  "solid",
                  "dashed",
                  "dotted"
                ]
              },
              "color": {
                "type": "string"
              },
              "label": {
                "type": "object",
                "additionalProperties": true
              }
            }
          }
        }
      },
      "entity": {
        "type": "object",
        "additionalProperties": true,
        "required": [
          "id",
          "label",
          "kind"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "label": {
            "type": "string",
            "minLength": 1
          },
          "kind": {
            "type": "string",
            "enum": [
              "client",
              "pc",
              "mobile",
              "cdn",
              "gateway",
              "nginx",
              "api_gateway",
              "service",
              "microservice",
              "registry",
              "nacos",
              "admin",
              "database",
              "mysql",
              "cache",
              "redis",
              "storage",
              "oss",
              "file_storage",
              "block_storage",
              "queue",
              "log",
              "elasticsearch",
              "security",
              "external",
              "cluster",
              "zone"
            ]
          },
          "zone": {
            "type": "string"
          },
          "position": {
            "$ref": "#/$defs/point2"
          },
          "lane": {
            "type": "string"
          },
          "icon": {
            "type": "string"
          },
          "provider": {
            "type": "string"
          },
          "service": {
            "type": "string"
          },
          "platform": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "size": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "w": {
                "type": "number",
                "exclusiveMinimum": 0
              },
              "d": {
                "type": "number",
                "exclusiveMinimum": 0
              },
              "h": {
                "type": "number",
                "exclusiveMinimum": 0
              }
            }
          },
          "presentation": {
            "type": "object",
            "additionalProperties": true,
            "properties": {
              "model": {
                "type": "string"
              },
              "icon": {
                "type": "string"
              },
              "shape": {
                "type": "string"
              },
              "color": {
                "type": "string"
              },
              "leaderLine": {
                "type": "boolean",
                "default": true
              },
              "label": {
                "type": "object",
                "additionalProperties": true,
                "properties": {
                  "mode": {
                    "type": "string",
                    "enum": [
                      "top",
                      "inline",
                      "hidden"
                    ],
                    "default": "top"
                  },
                  "leaderLine": {
                    "type": "boolean",
                    "default": true
                  }
                }
              }
            }
          },
          "summary": {
            "type": "string"
          },
          "details": {
            "type": "string"
          },
          "importance": {
            "type": "number",
            "minimum": 0
          },
          "visibility": {
            "type": "string",
            "enum": [
              "overview",
              "normal",
              "detail",
              "hidden"
            ]
          },
          "labelPriority": {
            "type": "string",
            "enum": [
              "always",
              "important",
              "normal",
              "hover",
              "hidden"
            ]
          }
        }
      },
      "link": {
        "type": "object",
        "additionalProperties": true,
        "required": [
          "id",
          "from",
          "to",
          "label",
          "directed"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "from": {
            "type": "string",
            "minLength": 1
          },
          "to": {
            "type": "string",
            "minLength": 1
          },
          "label": {
            "type": "string",
            "minLength": 1,
            "maxLength": 40
          },
          "directed": {
            "type": "boolean",
            "const": true
          },
          "kind": {
            "type": "string",
            "enum": [
              "api_call",
              "static_resource",
              "reverse_proxy",
              "load_balancing",
              "register",
              "registering_service",
              "pull_consumption",
              "health_check",
              "data_cache",
              "data_storage",
              "replication",
              "distributed_file_service",
              "feign_call",
              "log_collection"
            ]
          },
          "routeStyle": {
            "type": "string",
            "enum": [
              "straight",
              "orthogonal",
              "polyline"
            ],
            "default": "orthogonal"
          },
          "route": {
            "type": "array",
            "items": {
              "$ref": "#/$defs/point2"
            },
            "description": "Explicit route bend points in canvas x/y coordinates."
          },
          "points": {
            "type": "array",
            "items": {
              "$ref": "#/$defs/point2"
            },
            "description": "Alias for route."
          },
          "presentation": {
            "type": "object",
            "additionalProperties": true,
            "properties": {
              "stroke": {
                "type": "string"
              },
              "color": {
                "type": "string"
              },
              "width": {
                "type": "number",
                "exclusiveMinimum": 0
              },
              "arrow": {
                "type": "string",
                "enum": [
                  "forward",
                  "reverse",
                  "none"
                ],
                "default": "forward"
              },
              "lineStyle": {
                "type": "string",
                "enum": [
                  "solid",
                  "dashed",
                  "dotted"
                ]
              },
              "labelMode": {
                "type": "string",
                "enum": [
                  "always",
                  "overview",
                  "hover",
                  "hidden"
                ],
                "default": "overview"
              }
            }
          },
          "summary": {
            "type": "string"
          },
          "details": {
            "type": "string"
          },
          "importance": {
            "type": "number",
            "minimum": 0
          },
          "visibility": {
            "type": "string",
            "enum": [
              "overview",
              "normal",
              "detail",
              "hidden"
            ]
          },
          "labelPriority": {
            "type": "string",
            "enum": [
              "always",
              "important",
              "normal",
              "hover",
              "hidden"
            ]
          }
        }
      },
      "annotation": {
        "type": "object",
        "additionalProperties": true,
        "properties": {
          "id": {
            "type": "string"
          },
          "target_id": {
            "type": "string"
          },
          "target": {
            "type": "string"
          },
          "label": {
            "type": "string"
          },
          "summary": {
            "type": "string"
          },
          "priority": {
            "type": "number"
          }
        }
      }
    }
  },
  "example": {
    "schema": "efp.visual.input.isometric_architecture.v1",
    "title": "Compact Service Architecture",
    "subtitle": "Gateway, service, cache, and database overview",
    "goal": "Show the first-hop request path and the stateful dependencies.",
    "theme": "architecture_light",
    "canvas": {
      "grid": {
        "enabled": true,
        "step": 1
      }
    },
    "zones": [
      {
        "id": "edge-zone",
        "label": "Edge",
        "bounds": {
          "x": 0,
          "y": 0,
          "w": 4,
          "h": 4
        },
        "style": "dashed"
      },
      {
        "id": "service-zone",
        "label": "Services",
        "bounds": {
          "x": 5,
          "y": 0,
          "w": 5,
          "h": 4
        },
        "style": "dashed"
      },
      {
        "id": "data-zone",
        "label": "Data",
        "bounds": {
          "x": 5,
          "y": 5,
          "w": 5,
          "h": 3
        },
        "style": "dotted"
      }
    ],
    "entities": [
      {
        "id": "nginx",
        "label": "Nginx",
        "kind": "nginx",
        "zone": "edge-zone",
        "position": {
          "x": 2,
          "y": 2
        },
        "importance": 0.9
      },
      {
        "id": "order-service",
        "label": "Order Service",
        "kind": "microservice",
        "zone": "service-zone",
        "position": {
          "x": 7,
          "y": 2
        },
        "importance": 0.9
      },
      {
        "id": "redis",
        "label": "Redis",
        "kind": "redis",
        "zone": "data-zone",
        "position": {
          "x": 6.5,
          "y": 6.2
        }
      },
      {
        "id": "mysql",
        "label": "MySQL",
        "kind": "mysql",
        "zone": "data-zone",
        "position": {
          "x": 8.8,
          "y": 6.2
        }
      }
    ],
    "links": [
      {
        "id": "nginx-to-order",
        "from": "nginx",
        "to": "order-service",
        "label": "API",
        "directed": true,
        "kind": "reverse_proxy",
        "routeStyle": "orthogonal"
      },
      {
        "id": "order-to-redis",
        "from": "order-service",
        "to": "redis",
        "label": "Cache",
        "directed": true,
        "kind": "data_cache",
        "routeStyle": "orthogonal"
      },
      {
        "id": "order-to-mysql",
        "from": "order-service",
        "to": "mysql",
        "label": "Store",
        "directed": true,
        "kind": "data_storage",
        "routeStyle": "orthogonal"
      }
    ],
    "controls": [
      "overview",
      "reset_camera",
      "focus",
      "isolate",
      "hide_others",
      "show_all",
      "toggle_labels",
      "toggle_boundaries",
      "toggle_arrows",
      "export_json"
    ],
    "visual": {
      "assumptions": [
        "Service instances are grouped as one logical entity unless the architecture requires individual replicas."
      ],
      "initial_focus_ids": [
        "nginx",
        "order-service",
        "mysql"
      ]
    }
  }
}
