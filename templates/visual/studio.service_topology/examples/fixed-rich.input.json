{
  "schema": "efp.visual.input.studio.v1",
  "title": "AWS Order Processing Studio",
  "goal": "Explain the checkout topology, async fulfillment path, and operational risks.",
  "audience": "platform engineer",
  "assumptions": ["Only customer-facing order creation and fulfillment events are in scope."],
  "hero": {
    "type": "topology",
    "title": "AWS Order Processing",
    "summary": "Gateway, Lambda services, queue, event bus, database, and observability.",
    "data": {
      "nodes": [
        {"id": "client", "label": "Buyer", "kind": "user", "provider": "aws", "service": "cloudfront", "platform": "aws", "status": "ok", "importance": 0.7, "summary": "Customer placing an order.", "presentation": {"shape": "actor_card", "icon": "generic.user", "color": "#e5a84c"}},
        {"id": "api", "label": "API Gateway", "kind": "api", "provider": "aws", "service": "api_gateway", "platform": "aws", "status": "ok", "importance": 0.9, "summary": "Ingress for checkout requests.", "presentation": {"shape": "hex_service", "icon": "aws.api_gateway", "color": "#38bdf8"}},
        {"id": "orders", "label": "Orders Lambda", "kind": "service", "provider": "aws", "service": "lambda", "platform": "aws", "status": "ok", "importance": 0.94, "summary": "Creates orders and emits fulfillment events.", "presentation": {"shape": "service_box", "icon": "aws.lambda", "color": "#22c55e"}},
        {"id": "db", "label": "Orders RDS", "kind": "database", "provider": "aws", "service": "rds", "platform": "aws", "status": "ok", "importance": 0.82, "summary": "Stores order state.", "presentation": {"shape": "database_cylinder", "icon": "aws.rds", "color": "#60a5fa"}},
        {"id": "queue", "label": "Fulfillment Queue", "kind": "queue", "provider": "aws", "service": "sqs", "platform": "aws", "status": "warning", "importance": 0.88, "summary": "Buffers fulfillment work.", "presentation": {"shape": "queue_capsule", "icon": "aws.sqs", "color": "#f59e0b"}},
        {"id": "events", "label": "Order Events", "kind": "event_stream", "provider": "aws", "service": "eventbridge", "platform": "aws", "status": "ok", "importance": 0.76, "summary": "Publishes order lifecycle events.", "presentation": {"shape": "event_bus", "icon": "aws.eventbridge", "color": "#a78bfa"}},
        {"id": "watch", "label": "CloudWatch", "kind": "service", "provider": "aws", "service": "cloudwatch", "platform": "aws", "status": "ok", "importance": 0.68, "summary": "Monitors errors, queue age, and latency.", "presentation": {"shape": "service_box", "icon": "aws.cloudwatch", "color": "#fb7185"}}
      ],
      "edges": [
        {"id": "client-to-api", "from": "client", "to": "api", "kind": "calls", "label": "submits", "directed": true, "importance": 0.76, "summary": "Buyer submits checkout.", "presentation": {"arrow": "forward", "lineStyle": "solid", "flow": true}},
        {"id": "api-to-orders", "from": "api", "to": "orders", "kind": "calls", "label": "invokes", "directed": true, "importance": 0.9, "summary": "Gateway invokes order service.", "presentation": {"arrow": "forward", "lineStyle": "solid", "flow": true}},
        {"id": "orders-to-db", "from": "orders", "to": "db", "kind": "writes", "label": "writes", "directed": true, "importance": 0.82, "summary": "Order state is persisted.", "presentation": {"arrow": "forward", "lineStyle": "solid", "flow": true}},
        {"id": "orders-to-queue", "from": "orders", "to": "queue", "kind": "emits", "label": "queues", "directed": true, "importance": 0.86, "summary": "Fulfillment work is queued.", "presentation": {"arrow": "forward", "lineStyle": "dashed", "flow": true}},
        {"id": "orders-to-events", "from": "orders", "to": "events", "kind": "emits", "label": "publishes", "directed": true, "importance": 0.74, "summary": "Order lifecycle event is published.", "presentation": {"arrow": "forward", "lineStyle": "dashed", "flow": true}},
        {"id": "queue-to-watch", "from": "queue", "to": "watch", "kind": "observes", "label": "alarms", "directed": true, "importance": 0.66, "summary": "Queue age alarm is monitored.", "presentation": {"arrow": "forward", "lineStyle": "dotted", "flow": false}}
      ],
      "events": [
        {"id": "queue-age", "label": "Queue age warning", "kind": "risk", "status": "warning", "summary": "Fulfillment queue age rose for 12 minutes.", "presentation": {"shape": "warning_prism", "icon": "generic.warning", "color": "#f59e0b"}}
      ]
    }
  },
  "navigation": [
    {"id": "nav-overview", "label": "Overview", "target_id": "overview-panel", "icon": "generic.service", "summary": "Topology summary."},
    {"id": "nav-orders", "label": "Orders", "target_id": "orders-panel", "icon": "aws.lambda", "summary": "Core service."},
    {"id": "nav-risk", "label": "Queue Risk", "target_id": "queue-panel", "icon": "generic.warning", "summary": "Async risk."}
  ],
  "panels": [
    {"id": "overview-panel", "type": "overview", "title": "Topology Overview", "target_refs": ["client", "api", "orders", "db", "queue"], "summary": "Orders Lambda sits between ingress, persistence, and async fulfillment.", "items": [{"label": "critical path", "value": "client -> api -> orders -> db"}], "metrics": [{"label": "services", "value": "7"}], "evidence": [{"label": "architecture review", "source": "platform"}], "content": {"owner": "checkout platform"}, "presentation": {"shape": "service_box", "icon": "generic.service"}},
    {"id": "orders-panel", "type": "service", "title": "Orders Lambda", "target_refs": ["orders", "api-to-orders", "orders-to-db", "orders-to-queue"], "summary": "Orders owns creation, persistence, and event publication.", "items": [{"label": "runtime", "value": "lambda"}], "metrics": [{"label": "p95", "value": "220ms"}], "evidence": [{"label": "runbook", "source": "orders"}], "content": {"owner": "checkout team", "failure_mode": "queue backpressure"}, "presentation": {"shape": "service_box", "icon": "aws.lambda"}},
    {"id": "queue-panel", "type": "risk", "title": "Fulfillment Queue Risk", "target_refs": ["queue", "queue-age", "queue-to-watch"], "summary": "Queue age is the operational watch item.", "items": [{"label": "risk", "value": "delayed fulfillment"}], "metrics": [{"label": "oldest message", "value": "12m"}], "evidence": [{"label": "CloudWatch alarm", "source": "cloudwatch"}], "content": {"next_action": "Focus queue and watch alarm trend."}, "presentation": {"shape": "warning_prism", "icon": "generic.warning"}}
  ],
  "controls": [
    {"id": "focus-critical", "label": "Critical path", "type": "focus", "target": "orders", "action": "focus_path"},
    {"id": "filter-aws", "label": "AWS", "type": "filter", "target": "provider", "action": "aws"},
    {"id": "show-risk", "label": "Risk", "type": "toggle", "target": "queue-panel", "action": "show"}
  ],
  "annotations": [
    {"id": "anno-orders", "label": "Core", "target_id": "orders", "summary": "Primary orchestration service."},
    {"id": "anno-queue", "label": "Risk", "target_id": "queue", "summary": "Queue age is rising."}
  ],
  "view": {"colorBy": "provider", "mode": "overview", "labelMode": "overview"},
  "renderHints": {"showLegend": true, "palette": "cloud_provider", "iconMode": "billboard", "colorBy": "provider"},
