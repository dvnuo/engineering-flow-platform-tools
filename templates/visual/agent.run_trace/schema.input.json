{
  "schema": "efp.visual.template_input_schema.v1",
  "template_id": "agent.run_trace",
  "input_schema_kind": "graph_events_v1",
  "json_schema": {
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "efp.visual.input.graph_events.v1",
    "title": "EFP Visual Graph Events Input v1",
    "description": "Graph input with optional event stream for offline visual templates.",
    "type": "object",
    "required": [
      "nodes"
    ],
    "additionalProperties": true,
    "properties": {
      "schema": {
        "type": "string",
        "const": "efp.visual.input.graph_events.v1"
      },
      "title": {
        "type": "string"
      },
      "nodes": {
        "type": "array",
        "items": {
          "$ref": "#/$defs/node"
        }
      },
      "edges": {
        "type": "array",
        "items": {
          "$ref": "#/$defs/edge"
        }
      },
      "events": {
        "type": "array",
        "items": {
          "$ref": "#/$defs/event"
        }
      }
    },
    "$defs": {
      "object": {
        "type": "object",
        "additionalProperties": true
      },
      "node": {
        "type": "object",
        "required": [
          "id"
        ],
        "additionalProperties": true,
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "label": {
            "type": "string"
          },
          "kind": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "group": {
            "type": "string"
          },
          "metadata": {
            "$ref": "#/$defs/object"
          },
          "metrics": {
            "$ref": "#/$defs/object"
          }
        }
      },
      "edge": {
        "type": "object",
        "required": [
          "from",
          "to"
        ],
        "additionalProperties": true,
        "properties": {
          "from": {
            "type": "string",
            "minLength": 1
          },
          "to": {
            "type": "string",
            "minLength": 1
          },
          "kind": {
            "type": "string"
          },
          "label": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "weight": {
            "type": "number"
          },
          "metadata": {
            "$ref": "#/$defs/object"
          }
        }
      },
      "event": {
        "type": "object",
        "required": [
          "id"
        ],
        "additionalProperties": true,
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "time": {
            "type": "string",
            "format": "date-time"
          },
          "kind": {
            "type": "string"
          },
          "node_id": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "label": {
            "type": "string"
          },
          "summary": {
            "type": "string"
          },
          "payload": {
            "$ref": "#/$defs/object"
          }
        }
      }
    }
  },
  "example": {
    "schema": "efp.visual.input.graph_events.v1",
    "title": "Smoke Agent Run Trace",
    "nodes": [
      {
        "id": "request",
        "label": "User request",
        "kind": "input",
        "status": "success",
        "group": "phase"
      },
      {
        "id": "planning",
        "label": "Planning",
        "kind": "agent",
        "status": "success",
        "group": "phase"
      },
      {
        "id": "read_files",
        "label": "Read files",
        "kind": "tool",
        "status": "success",
        "group": "tool"
      },
      {
        "id": "run_tests",
        "label": "Run tests",
        "kind": "tool",
        "status": "warning",
        "group": "tool"
      },
      {
        "id": "final",
        "label": "Final answer",
        "kind": "response",
        "status": "success",
        "group": "phase"
      }
    ],
    "edges": [
      {
        "from": "request",
        "to": "planning",
        "kind": "step",
        "label": "analyze"
      },
      {
        "from": "planning",
        "to": "read_files",
        "kind": "tool",
        "label": "inspect"
      },
      {
        "from": "read_files",
        "to": "run_tests",
        "kind": "tool",
        "label": "verify"
      },
      {
        "from": "run_tests",
        "to": "final",
        "kind": "step",
        "label": "report"
      }
    ],
    "events": [
      {
        "id": "e1",
        "time": "2026-06-03T12:00:00Z",
        "kind": "request",
        "node_id": "request",
        "summary": "User asked for offline artifact CLI."
      },
      {
        "id": "e2",
        "time": "2026-06-03T12:02:00Z",
        "kind": "planning",
        "node_id": "planning",
        "summary": "Plan created."
      },
      {
        "id": "e3",
        "time": "2026-06-03T12:04:00Z",
        "kind": "tool_started",
        "node_id": "read_files",
        "summary": "Repository files inspected."
      },
      {
        "id": "e4",
        "time": "2026-06-03T12:08:00Z",
        "kind": "tool_finished",
        "node_id": "run_tests",
        "summary": "Tests completed with one warning."
      },
      {
        "id": "e5",
        "time": "2026-06-03T12:10:00Z",
        "kind": "response",
        "node_id": "final",
        "summary": "Final summary returned."
      }
    ]
  }
}
