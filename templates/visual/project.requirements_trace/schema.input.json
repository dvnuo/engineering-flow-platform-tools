{
  "schema": "efp.visual.template_input_schema.v1",
  "template_id": "project.requirements_trace",
  "input_schema_kind": "graph_v1",
  "json_schema": {
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "efp.visual.input.graph.v1",
    "title": "EFP Visual Graph Input v1",
    "description": "Graph input for offline visual templates.",
    "type": "object",
    "required": [
      "nodes"
    ],
    "additionalProperties": true,
    "properties": {
      "schema": {
        "type": "string",
        "const": "efp.visual.input.graph.v1"
      },
      "title": {
        "type": "string"
      },
      "nodes": {
        "type": "array",
        "items": {
          "$ref": "#/$defs/node"
        }
      },
      "edges": {
        "type": "array",
        "items": {
          "$ref": "#/$defs/edge"
        }
      }
    },
    "$defs": {
      "object": {
        "type": "object",
        "additionalProperties": true
      },
      "node": {
        "type": "object",
        "required": [
          "id"
        ],
        "additionalProperties": true,
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "label": {
            "type": "string"
          },
          "kind": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "group": {
            "type": "string"
          },
          "metadata": {
            "$ref": "#/$defs/object"
          },
          "metrics": {
            "$ref": "#/$defs/object"
          }
        }
      },
      "edge": {
        "type": "object",
        "required": [
          "from",
          "to"
        ],
        "additionalProperties": true,
        "properties": {
          "from": {
            "type": "string",
            "minLength": 1
          },
          "to": {
            "type": "string",
            "minLength": 1
          },
          "kind": {
            "type": "string"
          },
          "label": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "weight": {
            "type": "number"
          },
          "metadata": {
            "$ref": "#/$defs/object"
          }
        }
      }
    }
  },
  "example": {
    "schema": "efp.visual.input.graph.v1",
    "title": "Requirements Trace",
    "nodes": [
      {
        "id": "requirement",
        "label": "Requirement",
        "kind": "requirement",
        "status": "success"
      },
      {
        "id": "doc",
        "label": "Confluence doc",
        "kind": "doc",
        "status": "info"
      },
      {
        "id": "jira",
        "label": "Jira issue",
        "kind": "issue",
        "status": "success"
      },
      {
        "id": "pr",
        "label": "Pull request",
        "kind": "pull_request",
        "status": "pending"
      },
      {
        "id": "files",
        "label": "Changed files",
        "kind": "file",
        "status": "warning"
      },
      {
        "id": "tests",
        "label": "Tests",
        "kind": "test",
        "status": "pending"
      }
    ],
    "edges": [
      {
        "from": "requirement",
        "to": "doc",
        "kind": "documented_by"
      },
      {
        "from": "doc",
        "to": "jira",
        "kind": "tracked_by"
      },
      {
        "from": "jira",
        "to": "pr",
        "kind": "implemented_by"
      },
      {
        "from": "pr",
        "to": "files",
        "kind": "changes"
      },
      {
        "from": "files",
        "to": "tests",
        "kind": "verified_by"
      }
    ]
  }
}
