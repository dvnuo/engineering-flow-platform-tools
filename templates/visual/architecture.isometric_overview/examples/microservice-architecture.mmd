architecture-beta
  group client(cloud)[Client Zone]
  group edge(server)[Edge Zone]
  group gateway(server)[Gateway Zone]
  group services(server)[Service Zone]
  group data(database)[Data Zone]

  service pc(internet)[PC] in client
  service cdn(cloud)[CDN] in client
  service nginx(server)[Nginx] in edge
  service api(server)[API Gateway] in gateway
  service order(server)[Order Service] in services
  service payment(server)[Payment Service] in services
  service redis(database)[Redis Cache] in data
  service mysql(database)[MySQL] in data

  pc:R --> L:nginx
  cdn:R --> L:nginx
  nginx:R --> L:api
  api:R --> L:order
  api:R --> L:payment
  order:B --> T:redis
  order:B --> T:mysql
