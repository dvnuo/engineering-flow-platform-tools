{
  "schema": "efp.visual.input.uml.state_machine.v1",
  "title": "Agent Run State Machine",
  "states": [
    {
      "id": "queued",
      "label": "Queued",
      "kind": "initial",
      "region": "run",
      "entry": "reserve worker",
      "status": "ok"
    },
    {
      "id": "planning",
      "label": "Planning",
      "kind": "state",
      "region": "run",
      "entry": "read prompt",
      "status": "running"
    },
    {
      "id": "editing",
      "label": "Editing",
      "kind": "state",
      "region": "run",
      "entry": "modify files",
      "status": "running"
    },
    {
      "id": "verifying",
      "label": "Verifying",
      "kind": "state",
      "region": "run",
      "entry": "run tests",
      "status": "warning"
    },
    {
      "id": "blocked",
      "label": "Blocked",
      "kind": "state",
      "region": "exception",
      "entry": "request missing input",
      "status": "blocked"
    },
    {
      "id": "complete",
      "label": "Complete",
      "kind": "final",
      "region": "run",
      "entry": "report artifact",
      "status": "success"
    }
  ],
  "transitions": [
    {
      "from": "queued",
      "to": "planning",
      "trigger": "worker assigned",
      "action": "load workspace",
      "status": "success"
    },
    {
      "from": "planning",
      "to": "editing",
      "trigger": "plan accepted",
      "guard": "context complete",
      "status": "success"
    },
    {
      "from": "editing",
      "to": "verifying",
      "trigger": "files changed",
      "action": "run go test",
      "status": "running"
    },
    {
      "from": "verifying",
      "to": "editing",
      "trigger": "test failure",
      "guard": "fixable",
      "status": "warning"
    },
    {
      "from": "verifying",
      "to": "complete",
      "trigger": "all checks pass",
      "status": "success"
    },
    {
      "from": "planning",
      "to": "blocked",
      "trigger": "missing repo access",
      "status": "blocked"
    }
  ],
  "visual": {
    "goal": "Explain the uml state machine 3d by starting from the most important objects, then reveal supporting detail on demand.",
    "audience": "reviewer",
    "initial_focus_ids": [
      "queued",
      "planning",
      "editing"
    ],
    "hidden_detail_ids": [
      "verifying->complete",
      "planning->blocked"
    ],
    "emphasis": [
      "first-view clarity",
      "progressive detail",
      "semantic focus"
    ],
    "narrative_steps": [
      {
        "id": "overview",
        "title": "Start with the main actors",
        "summary": "Show the core entities and the relationship the viewer should understand first.",
        "focus_ids": [
          "queued",
          "planning",
          "editing"
        ]
      },
      {
        "id": "detail",
        "title": "Reveal supporting detail",
        "summary": "Use search, filters, or expansion for secondary evidence and implementation detail.",
        "focus_ids": [
          "editing",
          "verifying",
          "blocked"
        ]
      }
    ],
    "annotations": [
      {
        "id": "note-1",
        "target_id": "queued",
        "label": "Start here",
        "summary": "Use queued as a visual anchor for the uml state machine 3d story.",
        "priority": 1.0
      },
      {
        "id": "note-2",
        "target_id": "planning",
        "label": "Key relationship",
        "summary": "Use planning as a visual anchor for the uml state machine 3d story.",
        "priority": 0.82
      }
    ]
  }
}
