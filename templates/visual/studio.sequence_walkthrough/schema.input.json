{
  "schema": "efp.visual.template_input_schema.v1",
  "template_id": "studio.sequence_walkthrough",
  "input_schema_kind": "studio_v1",
  "json_schema": {
    "$schema": "json-schema-draft-2020-12",
    "type": "object",
    "additionalProperties": true,
    "required": ["schema", "hero", "panels"],
    "properties": {
      "schema": {"const": "efp.visual.input.studio.v1"},
      "title": {"type": "string"},
      "goal": {"type": "string"},
      "audience": {"type": "string"},
      "assumptions": {"type": "array", "items": {"type": "string"}},
      "hero": {
        "type": "object",
        "additionalProperties": true,
        "required": ["type", "title", "data"],
        "properties": {
          "type": {"type": "string"},
          "title": {"type": "string"},
          "summary": {"type": "string"},
          "data": {
            "type": "object",
            "additionalProperties": true,
            "properties": {
              "nodes": {"type": "array", "items": {"$ref": "#/$defs/studioObject"}},
              "items": {"type": "array", "items": {"$ref": "#/$defs/studioObject"}},
              "events": {"type": "array", "items": {"$ref": "#/$defs/studioObject"}},
              "participants": {"type": "array", "items": {"$ref": "#/$defs/studioObject"}},
              "edges": {"type": "array", "items": {"$ref": "#/$defs/studioEdge"}},
              "messages": {"type": "array", "items": {"$ref": "#/$defs/studioEdge"}}
            }
          }
        }
      },
      "navigation": {"type": "array", "items": {"$ref": "#/$defs/navigationItem"}},
      "panels": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/panel"}},
      "controls": {"type": "array", "items": {"$ref": "#/$defs/control"}},
      "annotations": {"type": "array", "items": {"$ref": "#/$defs/annotation"}},
      "view": {
        "type": "object",
        "additionalProperties": true,
        "properties": {
          "colorBy": {"type": "string"},
          "mode": {"type": "string"},
          "labelMode": {"type": "string"}
        }
      },
      "renderHints": {
        "type": "object",
        "additionalProperties": true,
        "properties": {
          "showLegend": {"type": "boolean"},
          "palette": {"type": "string"},
          "iconMode": {"type": "string"},
          "colorBy": {"type": "string"}
        }
      },
      "visual": {
        "type": "object",
        "additionalProperties": true,
        "properties": {
          "goal": {"type": "string"},
          "initial_focus_ids": {"type": "array", "items": {"type": "string"}},
          "hidden_detail_ids": {"type": "array", "items": {"type": "string"}},
          "narrative_steps": {"type": "array", "items": {"$ref": "#/$defs/narrativeStep"}},
          "annotations": {"type": "array", "items": {"$ref": "#/$defs/annotation"}}
        }
      }
    },
    "$defs": {
      "presentation": {
        "type": "object",
        "additionalProperties": true,
        "properties": {
          "shape": {"type": "string"},
          "mesh": {"type": "string"},
          "icon": {"type": "string"},
          "color": {"type": "string"},
          "arrow": {"type": "string", "enum": ["forward", "reverse", "none"]},
          "lineStyle": {"type": "string"},
          "flow": {"type": "boolean"}
        }
      },
      "studioObject": {
        "type": "object",
        "additionalProperties": true,
        "required": ["id"],
        "properties": {
          "id": {"type": "string"},
          "label": {"type": "string"},
          "title": {"type": "string"},
          "kind": {"type": "string"},
          "provider": {"type": "string"},
          "service": {"type": "string"},
          "platform": {"type": "string"},
          "status": {"type": "string"},
          "summary": {"type": "string"},
          "importance": {"type": "number"},
          "visibility": {"type": "string", "enum": ["overview", "normal", "detail", "hidden"]},
          "presentation": {"$ref": "#/$defs/presentation"},
          "metrics": {"type": "object"}
        }
      },
      "studioEdge": {
        "type": "object",
        "additionalProperties": true,
        "required": ["from", "to"],
        "properties": {
          "id": {"type": "string"},
          "from": {"type": "string"},
          "to": {"type": "string"},
          "label": {"type": "string"},
          "kind": {"type": "string"},
          "phase": {"type": "string"},
          "summary": {"type": "string"},
          "importance": {"type": "number"},
          "visibility": {"type": "string", "enum": ["overview", "normal", "detail", "hidden"]},
          "directed": {"type": "boolean"},
          "presentation": {"$ref": "#/$defs/presentation"}
        }
      },
      "navigationItem": {
        "type": "object",
        "additionalProperties": true,
        "properties": {
          "id": {"type": "string"},
          "label": {"type": "string"},
          "target_id": {"type": "string"},
          "icon": {"type": "string"},
          "summary": {"type": "string"}
        }
      },
      "panel": {
        "type": "object",
        "additionalProperties": true,
        "required": ["id", "type", "title"],
        "properties": {
          "id": {"type": "string"},
          "type": {"type": "string"},
          "title": {"type": "string"},
          "target_refs": {"type": "array", "items": {"type": "string"}},
          "summary": {"type": "string"},
          "items": {"type": "array", "items": {"type": "object"}},
          "metrics": {"type": "array", "items": {"type": "object"}},
          "evidence": {"type": "array", "items": {"type": "object"}},
          "content": {"type": "object"},
          "importance": {"type": "number"},
          "presentation": {"$ref": "#/$defs/presentation"}
        }
      },
      "control": {
        "type": "object",
        "additionalProperties": true,
        "required": ["id", "label", "type"],
        "properties": {
          "id": {"type": "string"},
          "label": {"type": "string"},
          "type": {"type": "string"},
          "target": {"type": "string"},
          "action": {"type": "string"}
        }
      },
      "annotation": {
        "type": "object",
        "additionalProperties": true,
        "required": ["id", "label", "target_id"],
        "properties": {
          "id": {"type": "string"},
          "label": {"type": "string"},
          "target_id": {"type": "string"},
          "summary": {"type": "string"},
          "priority": {"type": "number"}
        }
      },
      "narrativeStep": {
        "type": "object",
        "additionalProperties": true,
        "required": ["id", "title"],
        "properties": {
          "id": {"type": "string"},
          "title": {"type": "string"},
          "summary": {"type": "string"},
          "focus_ids": {"type": "array", "items": {"type": "string"}}
        }
      }
    }
  },
  "example": {
    "schema": "efp.visual.input.studio.v1",
    "title": "Sequence Walkthrough Studio Snapshot",
    "goal": "Explain the session start message path.",
    "audience": "gameplay engineer",
    "assumptions": ["CI and canary status are from the latest local evidence bundle."],
    "hero": {
      "type": "sequence",
      "title": "Game Session Walkthrough",
      "summary": "Participants, messages, and session events.",
      "data": {
        "nodes": [
          {"id": "build", "label": "Build", "kind": "job", "provider": "jenkins", "service": "jenkins", "platform": "jenkins", "status": "success", "importance": 0.9, "summary": "Build and tests passed.", "presentation": {"shape": "ci_card", "icon": "jenkins", "color": "#60a5fa"}},
          {"id": "canary", "label": "Canary", "kind": "service", "provider": "aws", "service": "lambda", "platform": "aws", "status": "warning", "importance": 0.86, "summary": "Canary has elevated latency.", "presentation": {"shape": "service_box", "icon": "aws.lambda", "color": "#f59e0b"}}
        ],
        "edges": [
          {"id": "build-to-canary", "from": "build", "to": "canary", "kind": "deploys", "label": "deploys", "directed": true, "importance": 0.82, "summary": "Build artifact deploys to canary.", "presentation": {"arrow": "forward", "lineStyle": "solid", "flow": true}}
        ]
      }
    },
    "navigation": [{"id": "nav-gate", "label": "Gate", "target_id": "gate-panel", "icon": "generic.decision", "summary": "Review canary gate."}],
    "panels": [{"id": "gate-panel", "type": "gate", "title": "Canary Gate", "target_refs": ["canary", "build-to-canary"], "summary": "Canary is the only watch item.", "metrics": [{"label": "latency p95", "value": "410ms"}], "evidence": [{"label": "CI run", "source": "jenkins"}], "content": {"status": "watch", "next_action": "Hold expansion until latency recovers."}, "presentation": {"shape": "service_box", "icon": "generic.decision"}}],
    "controls": [{"id": "focus-canary", "label": "Focus canary", "type": "focus", "target": "canary", "action": "focus"}],
    "annotations": [{"id": "canary-note", "label": "Watch", "target_id": "canary", "summary": "Latency is the release risk."}],
    "view": {"colorBy": "provider", "mode": "overview"},
    "renderHints": {"showLegend": true, "palette": "cloud_provider", "iconMode": "billboard", "colorBy": "provider"},
    "visual": {
      "goal": "Start with the canary gate.",
      "initial_focus_ids": ["build", "canary", "gate-panel"],
      "hidden_detail_ids": ["build-to-canary"],
      "narrative_steps": [{"id": "overview", "title": "Review the release path", "summary": "Build is clear and canary needs attention.", "focus_ids": ["build", "canary"]}],
      "annotations": [{"id": "visual-canary-note", "label": "Canary risk", "target_id": "canary", "summary": "Latency is above target.", "priority": 0.9}]
    }
  }
}
